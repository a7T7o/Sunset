{
    "hooks": {
      "UserPromptSubmit": [
        {
          "hooks": [
            {
              "type": "command",
              "command": ".claude/hooks/domain-rule-injector.sh"
            }
          ]
        }
      ],
      "PreToolUse": [
        {
          "matcher": "Bash(rm*|git reset --hard*|git push -f*)",
          "hooks": [
            {
              "type": "command",
              "command": ".claude/hooks/pre-bash-block.sh"
            }
          ]
        }
      ],
      "PostToolUse": [
        {
          "matcher": "Edit|Write",
          "hooks": [
            {
              "type": "command",
              "command": ".claude/hooks/post-edit-format.sh"
            }
          ]
        }
      ],
      "PreCompact": [
        {
          "matcher": "auto",
          "hooks": [
            {
              "type": "command",
              "command": ".claude/hooks/pre-compact-snapshot.sh"
            }
          ]
        }
      ],
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": ".claude/hooks/stop-update-memory.sh"
            }
          ]
        }
      ]
    }
  }
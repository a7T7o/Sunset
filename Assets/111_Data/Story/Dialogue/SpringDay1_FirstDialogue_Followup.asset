  sequenceId: spring-day1-first-followup
  nodes:
  - speakerName: 村长
    text: 年轻人，你还好吗？从天上掉下来，居然还活着。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 旅人
    text: 我……我在哪？刚才那句话，我忽然能听懂了。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 村长
    text: 这里是落日村。先离开矿洞口，那边有怪物，不适合久留。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 旅人
    text: 好，我跟你走。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0

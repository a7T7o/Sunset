  m_Script: {fileID: 11500000, guid: 6fd7c7e213ea3424784e4d44afe4baba, type: 3}
  m_Name: SpringDay1_FirstDialogue_Followup
  m_EditorClassIdentifier:
  sequenceId: spring-day1-first-followup
  nodes:
  - speakerName: 村长
    text: 能听懂了吗？先起来，矿洞口不安全。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 旅人
    text: 我……我居然真的听懂了。这里到底是什么地方？
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 村长
    text: 这里是落日村的矿洞外缘。先别问了，那边的动静不对。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: ""
    text: （矿洞深处传来骨头拖地的声响。那不是风声，也不像人。）
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 1
    isBubble: 0
    fontStyleKey: narration
    typingSpeedOverride: 0
  - speakerName: 村长
    text: 跟紧我。先离开这里，进村再说。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 旅人
    text: 好，我跟你走。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  canSkip: 1
  defaultTypingSpeed: 45
  markLanguageDecodedOnComplete: 0
  advanceStoryPhaseOnComplete: 1
  nextStoryPhase: 20
  followupSequence: {fileID: 11400000, guid: 848b3d9bebdc4efebbafa3f500912bc4, type: 2}

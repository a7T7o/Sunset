%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6fd7c7e213ea3424784e4d44afe4baba, type: 3}
  m_Name: SpringDay1_FirstDialogue_Followup
  m_EditorClassIdentifier:
  sequenceId: spring-day1-first-followup
  nodes:
  - speakerName: 村长
    text: 能听懂了吗？先起来，矿洞口不安全。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 旅人
    text: 我……我居然真的听懂了。我这是掉到了矿洞外？
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 村长
    text: 能动就先跟着我，脚下别踩空。这里不是让你慢慢想明白的地方。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 村长
    text: 先别问。听那边的声音，已经往外爬了。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: ""
    text: （矿洞深处传来骨头拖地的声响。那不是风声，也不像人，像有什么东西正沿着石壁朝我们摸过来。）
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 1
    isBubble: 0
    fontStyleKey: narration
    typingSpeedOverride: 0
  - speakerName: 旅人
    text: 那到底是什么东西？它一直在追我们？
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 村长
    text: 骷髅闻到活人的味就会追出来。跟紧我，沿着山路跑，别回头。先离开这里，进村再说。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 旅人
    text: 好，我跟你走。你带路，我不会掉队。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  canSkip: 1
  defaultTypingSpeed: 45
  markLanguageDecodedOnComplete: 0
  advanceStoryPhaseOnComplete: 1
  nextStoryPhase: 20
  followupSequence: {fileID: 11400000, guid: 848b3d9bebdc4efebbafa3f500912bc4, type: 2}

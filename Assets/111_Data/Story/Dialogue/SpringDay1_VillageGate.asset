    isBubble: 0
    fontStyleKey: narration
    typingSpeedOverride: 0
  - speakerName: 村长
    text: 先让路。人是我带回来的，今晚的事由我担着。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}

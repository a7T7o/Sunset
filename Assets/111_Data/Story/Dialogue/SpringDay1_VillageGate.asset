%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6fd7c7e213ea3424784e4d44afe4baba, type: 3}
  m_Name: SpringDay1_VillageGate
  m_EditorClassIdentifier:
  sequenceId: spring-day1-village-gate
  nodes:
  - speakerName: 村民
    text: 村长，你怎么带了个外乡人回来？
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 村民
    text: 又是矿洞那边捡回来的？今晚村里还要把他放进来？
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 小孩
    text: 他真的是从矿洞那边出来的吗？身上全是灰……
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: 村民
    text: 饭馆那边都听见你们回来的动静了。真要把他留在村里过夜？
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: ""
    text: （所有人的目光都落在我身上。这里没有一个人真正把我当成自己人，我只是被村长硬带进村里的外乡人。）
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 1
    isBubble: 0
    fontStyleKey: narration
    typingSpeedOverride: 0
  - speakerName: 村长
    text: 先让路。人是我带回来的，今晚的事由我担着。谁有话，等他先活过今晚再来问我。
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 0
    isBubble: 0
    fontStyleKey: default
    typingSpeedOverride: 0
  - speakerName: ""
    text: （他一句话把路压开了，可那不叫欢迎。更像是先替我挡下今晚，明天再把我重新推回所有人的眼睛里。）
    isGarbled: 0
    garbledText:
    speakerPortrait: {fileID: 0}
    isInnerMonologue: 1
    isBubble: 0
    fontStyleKey: narration
    typingSpeedOverride: 0
  canSkip: 1
  defaultTypingSpeed: 45
  markLanguageDecodedOnComplete: 0
  advanceStoryPhaseOnComplete: 0
  nextStoryPhase: 0
  followupSequence: {fileID: 0}

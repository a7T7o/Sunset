  m_Name: NPC_203_DinnerCrowdDialogueContent
  m_EditorClassIdentifier:
  npcId: 203
  selfTalkLines:
  - "\u4E00\u63D0\u90A3\u4EBA\u8DD1\u4E86\uFF0C\u6574\u5F20\u684C\u5B50\u5148\u9759\u534A\u53E3\u6C14\uFF0C\u53EA\u6709\u52FA\u5B50\u8FD8\u5728\u9505\u8FB9\u8F7B\u8F7B\u78B0\u3002"
  - "\u5634\u4E0A\u90FD\u8BF4\u4E0D\u997F\uFF0C\u53EF\u8C01\u771F\u8981\u56DE\u5C4B\u524D\u8DEF\u8FC7\u8FD9\u513F\uFF0C\u811A\u6B65\u8FD8\u662F\u4F1A\u6162\u4E0B\u6765\u3002"
  - "\u660E\u65E9\u6211\u7167\u65E7\u5F00\u706B\uFF0C\u4E0D\u80FD\u8BA9\u8FD9\u70B9\u70ED\u6C14\u4E5F\u8DDF\u7740\u6628\u665A\u6563\u4E86\u3002"
  phaseSelfTalkLines:
  - storyPhase: 60
    selfTalkLines:
    - "\u9505\u8FB9\u8FD9\u70B9\u70ED\u6C14\u4E0D\u80FD\u65AD\uFF0C\u7A7A\u7740\u809A\u5B50\u6700\u5BB9\u6613\u628A\u5FC3\u4E5F\u804A\u51C9\u3002"
    - "\u5148\u8BA9\u4EBA\u7AEF\u7A33\u7897\uFF0C\u518D\u542C\u4ED6\u4EEC\u628A\u540E\u534A\u53E5\u6162\u6162\u5410\u51FA\u6765\u3002"
  - storyPhase: 70
    selfTalkLines:
    - "\u56DE\u5C4B\u524D\u518D\u57AB\u4E24\u53E3\uFF0C\u522B\u8BA9\u80E1\u601D\u4E71\u60F3\u6BD4\u70ED\u6C64\u5148\u4E0A\u5934\u3002"
    - "\u706B\u53EF\u4EE5\u6536\u5C0F\uFF0C\u4EBA\u6C14\u4E0D\u80FD\u4E00\u4E0B\u6563\u5149\u3002"
  - storyPhase: 90
    selfTalkLines:
    - "\u660E\u65E9\u7167\u65E7\u5F00\u706B\uFF0C\u6751\u91CC\u624D\u50CF\u8FD8\u5728\u8FC7\u65E5\u5B50\u3002"
    - "\u5148\u628A\u6700\u540E\u56DE\u5C4B\u7684\u4EBA\u5582\u70ED\uFF0C\u518D\u8C08\u522B\u7684\u8BAE\u8BBA\u3002"
  playerNearbyLines:
  - "\u4F60\u5148\u522B\u6025\u7740\u8D70\uFF0C\u5916\u5934\u90A3\u9635\u4F4E\u58F0\u8BAE\u8BBA\u8FD8\u6CA1\u6563\uFF0C\u57AB\u4E24\u53E3\u518D\u56DE\u5C4B\u66F4\u7A33\u3002"
  - "\u521A\u624D\u6709\u51E0\u4E2A\u4EBA\u8FDE\u7897\u90FD\u7AEF\u8D77\u6765\u4E86\uFF0C\u53C8\u56E0\u4E3A\u684C\u4E0A\u592A\u9759\u81EA\u5DF1\u9ED8\u9ED8\u8BA9\u5F00\u4E86\u4F4D\u3002"
  - "\u56DE\u5C4B\u63D0\u9192\u5F52\u63D0\u9192\uFF0C\u6700\u540E\u771F\u80FD\u628A\u4EBA\u529D\u4F4F\u7684\uFF0C\u8FD8\u662F\u624B\u91CC\u8FD9\u53E3\u70ED\u6C64\u3002"
  relationshipStageNearbyLines: []
  phaseNearbyLines:
  - storyPhase: 60
    playerNearbyLines:
    - "\u5916\u5934\u8FD8\u5728\u4F4E\u58F0\u8BAE\u8BBA\uFF0C\u4F60\u5148\u522B\u7A7A\u7740\u809A\u5B50\u56DE\u5C4B\u3002"
    - "\u521A\u624D\u684C\u4E0A\u90A3\u534A\u53E3\u9759\u6C14\u8FD8\u5728\uFF0C\u4EBA\u5F97\u9760\u8FD9\u70B9\u70ED\u6C14\u628A\u5FC3\u6491\u4F4F\u3002"
  - storyPhase: 70
    playerNearbyLines:
    - "\u56DE\u5C4B\u524D\u57AB\u4E24\u53E3\u66F4\u7A33\uFF0C\u522B\u8BA9\u591C\u91CC\u7684\u80E1\u601D\u4E71\u60F3\u6BD4\u70ED\u6C64\u5148\u4E0A\u5934\u3002"
    - "\u73B0\u5728\u6700\u6015\u7684\u662F\u4EBA\u6563\u592A\u5FEB\uFF0C\u9505\u8FB9\u8FD9\u70B9\u70ED\u6C14\u4E5F\u8DDF\u7740\u706D\u4E86\u3002"
  - storyPhase: 90
    playerNearbyLines:
    - "\u660E\u65E9\u6211\u7167\u65E7\u5F00\u706B\uFF0C\u4E0D\u80FD\u8BA9\u8FD9\u70B9\u4EBA\u6C14\u8DDF\u6628\u665A\u4E00\u8D77\u6563\u6389\u3002"
    - "\u5148\u628A\u4EBA\u5582\u70ED\uFF0C\u5269\u4E0B\u90A3\u4E9B\u8BAE\u8BBA\u624D\u4E0D\u81F3\u4E8E\u8D8A\u804A\u8D8A\u51B7\u3002"
  defaultInformalConversationBundles:
  - bundleId: 203-hot-soup
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u4ECA\u5929\u770B\u8D77\u6765\u6BD4\u8C01\u90FD\u5FD9\u3002"
      - "\u662F\u4E0D\u662F\u5F88\u591A\u4EBA\u6765\u4F60\u8FD9\u513F\u8E6D\u53E3\u70ED\u7684\uFF1F"
      npcReplyLines:
      - "\u5FD9\u70B9\u597D\uFF0C\u5FD9\u7740\u76DB\u6C64\u603B\u6BD4\u5750\u7740\u60F3\u90A3\u4E9B\u70C2\u4E8B\u5F3A\u3002"
      - "\u518D\u8BF4\u5927\u5BB6\u90FD\u7D27\u7EF7\u7740\uFF0C\u603B\u5F97\u6709\u4EBA\u5148\u628A\u706B\u70B9\u8D77\u6765\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u4F60\u771F\u7684\u4E0D\u6015\u6751\u91CC\u518D\u4E71\u4E0B\u53BB\u5417\uFF1F"
      - "\u591C\u91CC\u8981\u662F\u51FA\u4E8B\uFF0C\u4F60\u4F1A\u600E\u4E48\u529E\uFF1F"
      npcReplyLines:
      - "\u6015\u554A\uFF0C\u53EF\u6015\u7684\u65F6\u5019\u66F4\u5F97\u8BA9\u9505\u91CC\u6709\u4E1C\u897F\uFF0C\u4EBA\u624D\u4E0D\u4F1A\u5148\u57AE\u3002"
      - "\u771F\u8981\u95F9\u8D77\u6765\uFF0C\u6211\u5148\u628A\u9505\u5B88\u4F4F\uFF0C\u522B\u8BA9\u4EBA\u997F\u7740\u80E1\u601D\u4E71\u60F3\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  phaseInformalChatSets:
  - storyPhase: 60
    conversationBundles:
    - bundleId: 203-dinner-resident
      exchanges:
      - exchangeId: exchange-1
        playerLines:
        - "\u684C\u4E0A\u90A3\u9635\u9759\u4E0B\u6765\u540E\uFF0C\u4F60\u8FD9\u8FB9\u662F\u4E0D\u662F\u53CD\u800C\u66F4\u5FD9\u4E86\uFF1F"
        - "\u73B0\u5728\u8FD8\u6709\u4EBA\u7ED5\u56DE\u6765\u60F3\u559D\u53E3\u70ED\u7684\u5417\uFF1F"
        npcReplyLines:
        - "\u66F4\u5FD9\uFF0C\u56E0\u4E3A\u8C01\u90FD\u4E0D\u60F3\u627F\u8BA4\u81EA\u5DF1\u5176\u5B9E\u8FD8\u60F3\u5728\u9505\u8FB9\u591A\u7AD9\u4E00\u4F1A\u513F\u3002"
        - "\u6709\uFF0C\u56DE\u5C4B\u524D\u8DEF\u8FC7\u7684\u4EBA\u603B\u4F1A\u6162\u4E0B\u6765\uFF0C\u50CF\u60F3\u518D\u501F\u4E00\u53E3\u70ED\u6C14\u538B\u4F4F\u5FC3\u91CC\u90A3\u9635\u4E71\u3002"
        npcReplyDelayMin: 0.52
        npcReplyDelayMax: 0.86
      completionRelationshipDelta: 1
    walkAwayReaction:

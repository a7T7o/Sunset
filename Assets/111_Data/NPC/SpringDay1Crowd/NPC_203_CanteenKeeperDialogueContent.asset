      playerExitLines:
      - "\u6211\u5148\u53BB\u7ED9\u4EBA\u76DB\u53E3\u70ED\u7684\u3002"
      - "\u8FD9\u9635\u684C\u8FB9\u7684\u9759\u6C14\u5F97\u9760\u70ED\u6C64\u538B\u4E00\u538B\u3002"
      npcReactionLines:

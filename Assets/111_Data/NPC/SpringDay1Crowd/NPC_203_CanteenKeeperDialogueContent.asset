  m_Script: {fileID: 11500000, guid: 7e1d8fd01cb8442eb570f1fd4d33ac41, type: 3}
  m_Name: NPC_203_DinnerCrowdDialogueContent
  m_EditorClassIdentifier: 
  npcId: 203
  selfTalkLines:
  - "\u4ECA\u5929\u53C8\u591A\u71AC\u4E86\u4E00\u9505\uFF0C\u614C\u7684\u65F6\u5019\u4EBA\u6700\u5BB9\u6613\u5FD8\u8BB0\u5403\u996D\u3002"
  - "\u6751\u957F\u4F1A\u8DD1\uFF0C\u809A\u5B50\u53EF\u4E0D\u4F1A\u81EA\u5DF1\u586B\u9971\u3002"
  - "\u5634\u4E0A\u90FD\u8BF4\u4E0D\u997F\uFF0C\u95FB\u89C1\u6C64\u5473\u8FD8\u662F\u4F1A\u5F80\u6211\u8FD9\u8FB9\u770B\u3002"
  playerNearbyLines:
  - "\u4F60\u8981\u662F\u665A\u70B9\u56DE\u53BB\uFF0C\u8BB0\u5F97\u5148\u57AB\u4E24\u53E3\uFF0C\u522B\u7A7A\u7740\u809A\u5B50\u625B\u591C\u3002"
  - "\u6211\u6700\u70E6\u90A3\u79CD\u8DD1\u4E86\u8FD8\u628A\u9505\u7529\u7ED9\u7559\u4E0B\u4EBA\u7684\u5BB6\u4F19\u3002"
  - "\u8981\u662F\u4F60\u4ECA\u665A\u8DEF\u8FC7\u6211\u90A3\u8FB9\uFF0C\u6211\u7ED9\u4F60\u7559\u4E00\u7897\u70ED\u7684\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 203-hot-soup
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u4ECA\u5929\u770B\u8D77\u6765\u6BD4\u8C01\u90FD\u5FD9\u3002"
      - "\u662F\u4E0D\u662F\u5F88\u591A\u4EBA\u6765\u4F60\u8FD9\u513F\u8E6D\u53E3\u70ED\u7684\uFF1F"
      npcReplyLines:
      - "\u5FD9\u70B9\u597D\uFF0C\u5FD9\u7740\u76DB\u6C64\u603B\u6BD4\u5750\u7740\u60F3\u90A3\u4E9B\u70C2\u4E8B\u5F3A\u3002"
      - "\u518D\u8BF4\u5927\u5BB6\u90FD\u7D27\u7EF7\u7740\uFF0C\u603B\u5F97\u6709\u4EBA\u5148\u628A\u706B\u70B9\u8D77\u6765\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u4F60\u771F\u7684\u4E0D\u6015\u6751\u91CC\u518D\u4E71\u4E0B\u53BB\u5417\uFF1F"
      - "\u591C\u91CC\u8981\u662F\u51FA\u4E8B\uFF0C\u4F60\u4F1A\u600E\u4E48\u529E\uFF1F"
      npcReplyLines:
      - "\u6015\u554A\uFF0C\u53EF\u6015\u7684\u65F6\u5019\u66F4\u5F97\u8BA9\u9505\u91CC\u6709\u4E1C\u897F\uFF0C\u4EBA\u624D\u4E0D\u4F1A\u5148\u57AE\u3002"
      - "\u8981\u662F\u771F\u51FA\u4E8B\uFF0C\u6211\u5148\u53EB\u4EBA\u5403\u9971\uFF0C\u518D\u9A82\u90A3\u5E2E\u88C5\u6B7B\u7684\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: "\u53BB\u5427\u53BB\u5427"
    playerExitLines:
    - "\u6211\u5148\u8D70\u4E00\u6B65\u3002"
    - "\u4F60\u8FD9\u9505\u6C64\u95FB\u5F97\u6211\u66F4\u997F\u4E86\u3002"
    npcReactionLines:
    - "\u90A3\u5C31\u522B\u7A7A\u7740\u809A\u5B50\u4E71\u8DD1\uFF0C\u56DE\u6765\u6211\u7ED9\u4F60\u76DB\u3002"
    - "\u4ECA\u665A\u60F3\u5403\u70ED\u7684\u5C31\u6765\u627E\u6211\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u4E00\u9505\u70ED\u6C64\u6BD4\u5341\u53E5\u7A7A\u5B89\u6170\u7BA1\u7528\uFF0C\u6211\u65E9\u5C31\u77E5\u9053\u4E86\u3002"
  - "\u8FD9\u6751\u5B50\u8FD8\u80FD\u7A33\u4F4F\uFF0C\u591A\u534A\u9760\u7684\u662F\u80AF\u7AEF\u52FA\u5B50\u7684\u4EBA\u3002"
  defaultChatResponderLines:
  - "\u53EF\u4E0D\u662F\u561B\uFF0C\u771F\u997F\u7684\u65F6\u5019\u8FDE\u9A82\u4EBA\u90FD\u6CA1\u529B\u6C14\u3002"
  - "\u6211\u5634\u4E0A\u51F6\u4E00\u70B9\uFF0C\u662F\u6015\u5927\u5BB6\u8FDE\u6C42\u52A9\u90FD\u4E0D\u597D\u610F\u601D\u5F00\u53E3\u3002"
  pairDialogueSets:
  - partnerNpcId: 101
    initiatorLines:
    - "\u4F60\u522B\u53C8\u5199\u5230\u5FD8\u4E86\u65F6\u8FB0\uFF0C\u665A\u70B9\u6211\u7ED9\u4F60\u9001\u7897\u70ED\u7684\u3002"
    - "\u4F60\u8FD9\u8FB9\u7EB8\u9875\u4E00\u645E\u9AD8\uFF0C\u4EBA\u5C31\u66F4\u5BB9\u6613\u628A\u809A\u5B50\u5FD8\u4E86\u3002"
    responderLines:
    - "\u884C\uFF0C\u6211\u628A\u8FD9\u4E00\u9875\u6536\u5C3E\u5C31\u53BB\u3002"
    - "\u6709\u4F60\u90A3\u9505\u70ED\u6C64\u6491\u7740\uFF0C\u5927\u5BB6\u624D\u6709\u529B\u6C14\u628A\u5B9E\u8BDD\u7EE7\u7EED\u5F80\u5916\u5012\u3002"
  - partnerNpcId: 103
    initiatorLines:
    - "\u4F60\u8DD1\u4E00\u5929\u4E5F\u8BE5\u505C\u4E0B\u6765\u559D\u4E24\u53E3\uFF0C\u4E0D\u7136\u56DE\u5FC6\u90FD\u8981\u5598\u6563\u4E86\u3002"
    - "\u522B\u8001\u8BF4\u81EA\u5DF1\u4E0D\u997F\uFF0C\u6211\u4E00\u770B\u5C31\u77E5\u9053\u4F60\u53C8\u7A7A\u7740\u809A\u5B50\u3002"
    responderLines:
    - "\u563F\uFF0C\u88AB\u4F60\u770B\u51FA\u6765\u4E86\u3002"
    - "\u6211\u559D\u4E24\u53E3\u518D\u8BB2\uFF0C\u90A3\u665A\u7684\u8DEF\u6211\u5C31\u80FD\u60F3\u5F97\u66F4\u6E05\u4E00\u70B9\u3002"
  - partnerNpcId: 104
    initiatorLines:
    - "\u4F60\u90A3\u8FB9\u6572\u6728\u677F\u6572\u5230\u8FD9\u4E48\u665A\uFF0C\u6211\u8FD9\u8FB9\u706B\u4E5F\u5C31\u4E0D\u6562\u706D\u3002"
    - "\u591C\u91CC\u6709\u4EBA\u542C\u89C1\u4F60\u6572\u6253\u7684\u58F0\u97F3\uFF0C\u5FC3\u91CC\u53CD\u5012\u4F1A\u7A33\u4E00\u70B9\u3002"
    responderLines:
    - "\u90A3\u4F60\u5C31\u628A\u706B\u7559\u7740\uFF0C\u6211\u628A\u80FD\u6321\u98CE\u7684\u5148\u5168\u8865\u4E0A\u3002"
    - "\u6751\u91CC\u53EA\u8981\u8FD8\u6709\u70ED\u6C14\u548C\u6572\u6253\u58F0\uFF0C\u5C31\u4E0D\u50CF\u5F7B\u5E95\u6563\u4E86\u3002"

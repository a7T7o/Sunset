  m_Script: {fileID: 11500000, guid: 7e1d8fd01cb8442eb570f1fd4d33ac41, type: 3}
  m_Name: NPC_301_NightWitnessDialogueContent
  m_EditorClassIdentifier: 
  npcId: 301
  selfTalkLines:
  - "\u540E\u5761\u90A3\u6761\u591C\u8DEF\u4E00\u5B89\u9759\u4E0B\u6765\uFF0C\u53CD\u800C\u66F4\u8BA9\u4EBA\u4E0D\u653E\u5FC3\u3002"
  - "\u771F\u6709\u4EBA\u534A\u591C\u4E71\u8DD1\uFF0C\u811A\u6B65\u603B\u4F1A\u6BD4\u767D\u5929\u66F4\u614C\u3002"
  - "\u6211\u4E0D\u7231\u5435\u95F9\uFF0C\u4F46\u591C\u91CC\u7684\u52A8\u9759\u5F97\u6709\u4EBA\u8BB0\u7740\u3002"
  playerNearbyLines:
  - "\u4ECA\u665A\u8981\u8D70\u591C\u8DEF\u7684\u8BDD\uFF0C\u8BB0\u5F97\u5148\u770B\u6E05\u811A\u4E0B\u3002"
  - "\u8981\u662F\u4F60\u4E5F\u5728\u627E\u90A3\u665A\u8DD1\u8D70\u7684\u4EBA\uFF0C\u540E\u5761\u90A3\u8FB9\u6700\u597D\u522B\u4E00\u4E2A\u4EBA\u53BB\u3002"
  - "\u56DE\u4F4F\u5904\u524D\u5148\u786E\u8BA4\u4E00\u4E0B\u8EAB\u540E\uFF0C\u591C\u91CC\u6700\u6015\u7684\u5C31\u662F\u4EBA\u5FC3\u53D1\u865A\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 301-bone-night
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u8BF4\u4F60\u542C\u89C1\u4E86\u90A3\u665A\u7684\u811A\u6B65\uFF1F"
      - "\u8FDE\u4F60\u90FD\u77E5\u9053\u6751\u957F\u5F80\u54EA\u8FB9\u8DD1\uFF1F"
      npcReplyLines:
      - "\u77E5\u9053\u4E00\u70B9\uFF0C\u5F80\u9ED1\u91CC\u8D76\u8DEF\u7684\u4EBA\u6700\u7231\u8E29\u90A3\u4E9B\u81EA\u5DF1\u4EE5\u4E3A\u6CA1\u4EBA\u4F1A\u6CE8\u610F\u7684\u788E\u77F3\u3002"
      - "\u6211\u4E0D\u66FF\u8C01\u6293\u4EBA\uFF0C\u53EA\u662F\u628A\u591C\u91CC\u7684\u52A8\u9759\u8BB0\u4F4F\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u90A3\u6211\u4ECA\u665A\u8BE5\u6CE8\u610F\u4EC0\u4E48\uFF1F"
      - "\u591C\u91CC\u771F\u7684\u4F1A\u66F4\u5371\u9669\u5417\uFF1F"
      npcReplyLines:
      - "\u6CE8\u610F\u90A3\u4E9B\u7A81\u7136\u592A\u5B89\u9759\u7684\u5730\u65B9\uFF0C\u5F80\u5F80\u6BD4\u6709\u58F0\u54CD\u7684\u5730\u65B9\u66F4\u503C\u5F97\u7559\u5FC3\u3002"
      - "\u5FEB\u5230\u4F4F\u5904\u65F6\u5C31\u522B\u72B9\u8C6B\u4E86\uFF0C\u591C\u91CC\u6700\u5BB9\u6613\u62D6\u4F4F\u4EBA\u7684\u5C31\u662F\u8FDF\u7591\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: "\u55EF"
    playerExitLines:
    - "\u6211\u5148\u56DE\u53BB\u4E86\u3002"
    - "\u591C\u91CC\u8FD9\u8BDD\u9898\u542C\u7740\u602A\u7606\u4EBA\u7684\u3002"
    npcReactionLines:
    - "\u56DE\u5427\uFF0C\u8D70\u591C\u8DEF\u7684\u65F6\u5019\u522B\u8001\u56DE\u5934\u4E71\u770B\u3002"
    - "\u522B\u8BA9\u591C\u91CC\u7684\u614C\u4E71\u66FF\u4F60\u505A\u51B3\u5B9A\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u6211\u4E0D\u8FFD\u4EBA\uFF0C\u6211\u53EA\u8BB0\u5F97\u8C01\u534A\u591C\u8E29\u8FC7\u540E\u5761\u90A3\u6761\u8DEF\u3002"
  - "\u591C\u91CC\u6700\u8BDA\u5B9E\u7684\u4E0D\u662F\u5634\uFF0C\u662F\u811A\u6B65\u3002"
  defaultChatResponderLines:
  - "\u6211\u4E0D\u5435\u4EBA\uFF0C\u53EA\u662F\u89C9\u5F97\u6709\u4E9B\u52A8\u9759\u4E0D\u8BB0\u4E0B\u6765\u5C31\u592A\u53EF\u60DC\u4E86\u3002"
  - "\u591C\u91CC\u7684\u4E8B\u60C5\u8BF4\u5F97\u6162\u4E00\u70B9\u4E5F\u6CA1\u5173\u7CFB\uFF0C\u91CD\u8981\u7684\u662F\u522B\u8BF4\u9519\u3002"
  pairDialogueSets:
  - partnerNpcId: 102
    initiatorLines:
    - "\u4F60\u522B\u53EA\u76EF\u7740\u5730\u4E0A\uFF0C\u591C\u91CC\u7684\u56DE\u58F0\u6BD4\u811A\u5370\u66F4\u4F1A\u544A\u5BC6\u3002"
    - "\u90A3\u4EBA\u8E29\u8FC7\u540E\u5761\u65F6\u5FC3\u8DF3\u4E71\u5F97\u5F88\u660E\u663E\uFF0C\u8FDE\u811A\u6B65\u90FD\u8E29\u5F97\u53D1\u98D8\u3002"
    responderLines:
    - "\u55EF\uFF0C\u4F60\u76EF\u9ED1\u91CC\u90A3\u4E00\u622A\uFF0C\u6211\u6765\u8FFD\u80FD\u770B\u89C1\u7684\u90A3\u534A\u7A0B\u3002"
    - "\u53EA\u8981\u56DE\u58F0\u548C\u811A\u5370\u5BF9\u4E0A\uFF0C\u4ED6\u518D\u4F1A\u85CF\u4E5F\u85CF\u4E0D\u4F4F\u3002"

  m_Name: NPC_301_GraveWardenBoneDialogueContent
  m_EditorClassIdentifier: 
  npcId: 301
  selfTalkLines:
  - "\u9AA8\u5934\u4E5F\u542C\u89C1\u4E86\u90A3\u665A\u7684\u811A\u6B65\uFF0C\u6025\u3001\u865A\u3001\u8FD8\u5E26\u7740\u6015\u3002"
  - "\u6D3B\u4EBA\u9003\u8DD1\u65F6\u6700\u5435\uFF0C\u504F\u504F\u603B\u4EE5\u4E3A\u81EA\u5DF1\u6CA1\u58F0\u54CD\u3002"
  - "\u591C\u91CC\u98CE\u4ECE\u540E\u5761\u5439\u4E0B\u6765\uFF0C\u5E26\u7740\u6CA1\u6765\u5F97\u53CA\u57CB\u597D\u7684\u5FC3\u865A\u3002"
  playerNearbyLines:
  - "\u522B\u79BB\u591C\u8DEF\u592A\u8FD1\uFF0C\u5C0F\u9AA8\u5934\u90FD\u77E5\u9053\u4ECA\u665A\u4E0D\u592A\u5E73\u3002"
  - "\u4F60\u82E5\u627E\u7684\u662F\u8DD1\u6389\u7684\u4EBA\uFF0C\u6211\u53EA\u80FD\u544A\u8BC9\u4F60\u4ED6\u6015\u7684\u6BD4\u4F60\u4EEC\u60F3\u7684\u8FD8\u91CD\u3002"
  - "\u56DE\u5C4B\u524D\u5148\u770B\u770B\u8EAB\u540E\uFF0C\u6D3B\u4EBA\u7684\u5FC3\u6BD4\u9AA8\u5934\u66F4\u4F1A\u62D0\u5F2F\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 301-bone-night
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u8BF4\u4F60\u542C\u89C1\u4E86\u90A3\u665A\u7684\u811A\u6B65\uFF1F"
      - "\u8FDE\u4F60\u90FD\u77E5\u9053\u6751\u957F\u5F80\u54EA\u8FB9\u8DD1\uFF1F"
      npcReplyLines:
      - "\u77E5\u9053\u4E00\u70B9\uFF0C\u5F80\u9ED1\u91CC\u94BB\u7684\u4EBA\u6700\u7231\u8E29\u7740\u4EE5\u4E3A\u6CA1\u4EBA\u4F1A\u542C\u89C1\u7684\u788E\u77F3\u3002"
      - "\u6211\u4E0D\u66FF\u4F60\u4EEC\u6293\u4EBA\uFF0C\u53EA\u66FF\u591C\u91CC\u8BB0\u56DE\u58F0\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u90A3\u6211\u4ECA\u665A\u8BE5\u6CE8\u610F\u4EC0\u4E48\uFF1F"
      - "\u591C\u91CC\u771F\u7684\u4F1A\u66F4\u5371\u9669\u5417\uFF1F"
      npcReplyLines:
      - "\u6CE8\u610F\u90A3\u4E9B\u5FFD\u7136\u592A\u5B89\u9759\u7684\u5730\u65B9\uFF0C\u5F80\u5F80\u6BD4\u6709\u58F0\u54CD\u7684\u5730\u65B9\u66F4\u50CF\u9677\u9631\u3002"
      - "\u5FEB\u5230\u5C4B\u5B50\u65F6\u522B\u72B9\u8C6B\uFF0C\u591C\u8272\u6700\u559C\u6B22\u54AC\u8FDF\u7591\u7684\u4EBA\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: "\u5494"
    playerExitLines:
    - "\u6211\u5148\u56DE\u53BB\u4E86\u3002"
    - "\u591C\u91CC\u8FD9\u8BDD\u9898\u542C\u7740\u602A\u7606\u4EBA\u7684\u3002"
    npcReactionLines:
    - "\u56DE\u5427\u56DE\u5427\uFF0C\u95E8\u540E\u9762\u6BD4\u95E8\u5916\u9762\u4EC1\u6148\u3002"
    - "\u522B\u8BA9\u591C\u8272\u66FF\u4F60\u505A\u51B3\u5B9A\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u6211\u4E0D\u8FFD\u4EBA\uFF0C\u6211\u53EA\u8BB0\u5F97\u8C01\u8E29\u8FC7\u575F\u5761\u8FB9\u90A3\u6761\u65E7\u8DEF\u3002"
  - "\u591C\u91CC\u6700\u8BDA\u5B9E\u7684\u4E0D\u662F\u5634\uFF0C\u662F\u811A\u6B65\u3002"
  defaultChatResponderLines:
  - "\u6840\u6840\uFF0C\u4E0D\u7528\u6015\u6211\uFF0C\u6015\u90A3\u4E9B\u8FD8\u6D3B\u7740\u5374\u4E0D\u6562\u627F\u8BA4\u7684\u4EBA\u5C31\u591F\u4E86\u3002"
  - "\u9AA8\u5934\u4E0D\u8BF4\u8C0E\uFF0C\u53EA\u662F\u8BF4\u5F97\u6162\u4E00\u70B9\u3002"
  pairDialogueSets:
  - partnerNpcId: 102
    initiatorLines:
    - "\u708E\u680E\uFF0C\u522B\u53EA\u76EF\u7740\u5730\u4E0A\uFF0C\u591C\u91CC\u7684\u56DE\u58F0\u6BD4\u811A\u5370\u66F4\u4F1A\u544A\u5BC6\u3002"
    - "\u90A3\u4EBA\u8E29\u8FC7\u575F\u5761\u8FB9\u65F6\u5FC3\u8DF3\u4E71\u5F97\u50CF\u6572\u574F\u4E86\u949F\u3002"
    responderLines:
    - "\u55EF\uFF0C\u4F60\u76EF\u9ED1\u91CC\u90A3\u4E00\u622A\uFF0C\u6211\u6765\u8FFD\u80FD\u770B\u89C1\u7684\u90A3\u534A\u7A0B\u3002"
    - "\u53EA\u8981\u56DE\u58F0\u548C\u811A\u5370\u5BF9\u4E0A\uFF0C\u4ED6\u518D\u4F1A\u85CF\u4E5F\u85CF\u4E0D\u4F4F\u3002"

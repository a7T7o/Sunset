        playerLines:
        - "\u6536\u591C\u4E4B\u540E\uFF0C\u8FD9\u6761\u5761\u8DEF\u4F1A\u5B89\u9759\u56DE\u53BB\u5417\uFF1F"
        - "\u5230\u660E\u65E9\u5927\u5BB6\u8FD8\u80FD\u628A\u6628\u665A\u90A3\u9635\u52A8\u9759\u88C5\u6CA1\u53D1\u751F\u5417\uFF1F"

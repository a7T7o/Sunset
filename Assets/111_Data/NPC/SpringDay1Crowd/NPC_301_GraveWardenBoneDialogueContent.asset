    interruptRules: []
    resumeRules: []
  - storyPhase: 80
    conversationBundles:
    - bundleId: 301-free-time-resident
      exchanges:
      - exchangeId: exchange-1
        playerLines:
        - "\u73B0\u5728\u591C\u91CC\u8FD9\u9635\u89C1\u95FB\uFF0C\u662F\u4E0D\u662F\u4F60\u6700\u8BE5\u51FA\u58F0\u7684\u65F6\u5019\uFF1F"
        - "\u771F\u6709\u4EBA\u591C\u91CC\u518D\u7ED5\u51FA\u53BB\uFF0C\u4F60\u4F1A\u5148\u542C\u89C1\u5417\uFF1F"
        npcReplyLines:
        - "\u662F\uFF0C\u767D\u5929\u538B\u4F4F\u7684\u8BDD\uFF0C\u5230\u8FD9\u4F1A\u513F\u603B\u4F1A\u4ECE\u8DEF\u9762\u548C\u56DE\u58F0\u91CC\u6F0F\u51FA\u6765\u3002"
        - "\u591A\u534A\u4F1A\uFF0C\u591C\u91CC\u6700\u5148\u4E71\u7684\u4E0D\u662F\u5F71\u5B50\uFF0C\u662F\u811A\u4E0B\u90A3\u4E00\u4E0B\u8FDF\u7591\u3002"
        npcReplyDelayMin: 0.52

  m_Name: NPC_301_NightWitnessDialogueContent
  m_EditorClassIdentifier:
  npcId: 301
  selfTalkLines:
  - "\u540E\u5761\u4E00\u5230\u6536\u591C\u90A3\u9635\uFF0C\u8FDE\u98CE\u90FD\u50CF\u5B88\u7740\u89C4\u77E9\uFF0C\u4E0D\u80AF\u591A\u66FF\u8C01\u63A9\u4E00\u58F0\u3002"
  - "\u771F\u6709\u4EBA\u534A\u591C\u5F80\u9ED1\u91CC\u94BB\uFF0C\u56DE\u4F4F\u5904\u524D\u90A3\u51E0\u6B65\u53CD\u5012\u6700\u5BB9\u6613\u6F0F\u51FA\u614C\u3002"
  - "\u6751\u91CC\u591C\u91CC\u7167\u65E7\u8981\u7184\u58F0\uFF0C\u53EF\u6628\u665A\u90A3\u6761\u8DEF\u5230\u73B0\u5728\u8FD8\u6CA1\u5B89\u9759\u56DE\u53BB\u3002"
  phaseSelfTalkLines:
  - storyPhase: 70
    selfTalkLines:
    - "\u56DE\u5C4B\u524D\u90A3\u51E0\u6B65\u5148\u653E\u8F7B\uFF0C\u540E\u5761\u6700\u4F1A\u628A\u8FDF\u7591\u653E\u5927\u3002"
    - "\u5148\u542C\u811A\u6B65\uFF0C\u4E0D\u6025\u7740\u542C\u4EBA\u8BF4\u8BDD\uFF0C\u591C\u91CC\u6536\u58F0\u6700\u80FD\u9732\u5E95\u3002"
  - storyPhase: 80
    selfTalkLines:
    - "\u591C\u8DEF\u4E00\u9759\u5F97\u8FC7\u5934\uFF0C\u591A\u534A\u5C31\u6709\u4E1C\u897F\u8FD8\u6CA1\u6563\u3002"
    - "\u5148\u628A\u81EA\u5DF1\u7684\u6B65\u5B50\u538B\u4F4F\uFF0C\u522B\u628A\u56DE\u58F0\u5168\u6405\u4E71\u4E86\u3002"
  - storyPhase: 90
    selfTalkLines:
    - "\u6536\u591C\u4EE5\u540E\u8DEF\u9762\u4F1A\u88C5\u4F5C\u7167\u5E38\uFF0C\u56DE\u58F0\u53EF\u4E0D\u4F1A\u3002"
    - "\u9E21\u53EB\u524D\u8FD9\u9635\u9ED1\uFF0C\u6700\u7231\u628A\u6CA1\u8BF4\u51FA\u53E3\u7684\u614C\u518D\u653E\u5927\u4E00\u5708\u3002"
  playerNearbyLines:
  - "\u56DE\u5C4B\u524D\u5148\u628A\u811A\u6B65\u6536\u4E00\u70B9\uFF0C\u540E\u5761\u90A3\u8FB9\u4ECA\u665A\u6709\u4EBA\u5728\u542C\u6709\u6CA1\u6709\u591A\u51FA\u6765\u7684\u52A8\u9759\u3002"
  - "\u8981\u662F\u4F60\u4E5F\u5728\u627E\u90A3\u665A\u7684\u56DE\u58F0\uFF0C\u5C31\u522B\u628A\u81EA\u5DF1\u8D70\u6210\u6700\u54CD\u7684\u90A3\u4E2A\u3002"
  - "\u591C\u91CC\u4E0D\u662F\u4E0D\u80FD\u8BF4\u8BDD\uFF0C\u662F\u522B\u8BA9\u5FC3\u865A\u62A2\u5728\u58F0\u97F3\u524D\u9762\u3002"
  relationshipStageNearbyLines: []
  phaseNearbyLines:
  - storyPhase: 70
    playerNearbyLines:
    - "\u56DE\u4F4F\u5904\u524D\u5148\u628A\u811A\u6B65\u6536\u4E00\u70B9\uFF0C\u540E\u5761\u8FD9\u4F1A\u513F\u6700\u4F1A\u653E\u5927\u8FDF\u7591\u3002"
    - "\u591C\u91CC\u4E0D\u662F\u4E0D\u80FD\u8D70\uFF0C\u53EA\u662F\u522B\u8BA9\u5FC3\u865A\u5148\u628A\u4F60\u811A\u6B65\u5356\u4E86\u3002"
  - storyPhase: 80
    playerNearbyLines:
    - "\u81EA\u7531\u65F6\u6BB5\u7684\u591C\u8DEF\u6700\u6015\u5FFD\u7136\u592A\u5B89\u9759\uFF0C\u90A3\u79CD\u5730\u65B9\u5F80\u5F80\u66F4\u6709\u4E1C\u897F\u3002"
    - "\u4F60\u8981\u771F\u60F3\u542C\u56DE\u58F0\uFF0C\u5C31\u522B\u628A\u81EA\u5DF1\u8D70\u6210\u6574\u5761\u6700\u54CD\u7684\u90A3\u4E2A\u3002"
  - storyPhase: 90
    playerNearbyLines:
    - "\u6536\u591C\u4EE5\u540E\u8DEF\u9762\u4F1A\u88C5\u4F5C\u7167\u5E38\uFF0C\u53EF\u6628\u665A\u90A3\u70B9\u56DE\u58F0\u8FD8\u6CA1\u771F\u6563\u3002"
    - "\u7B49\u9E21\u53EB\u524D\uFF0C\u591C\u8272\u603B\u7231\u628A\u6CA1\u8BF4\u51FA\u53E3\u7684\u614C\u653E\u5927\u4E00\u5708\u3002"
  defaultInformalConversationBundles:
  - bundleId: 301-bone-night
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u8BF4\u4F60\u542C\u89C1\u4E86\u90A3\u665A\u7684\u811A\u6B65\uFF1F"
      - "\u8FDE\u4F60\u90FD\u77E5\u9053\u6751\u957F\u5F80\u54EA\u8FB9\u8DD1\uFF1F"
      npcReplyLines:
      - "\u77E5\u9053\u4E00\u70B9\uFF0C\u5F80\u9ED1\u91CC\u94BB\u7684\u4EBA\u6700\u7231\u8E29\u7740\u4EE5\u4E3A\u6CA1\u4EBA\u4F1A\u542C\u89C1\u7684\u788E\u77F3\u3002"
      - "\u6211\u4E0D\u6293\u4EBA\uFF0C\u6211\u53EA\u628A\u591C\u91CC\u542C\u89C1\u7684\u52A8\u9759\u8BB0\u6E05\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u90A3\u6211\u4ECA\u665A\u8BE5\u6CE8\u610F\u4EC0\u4E48\uFF1F"
      - "\u591C\u91CC\u771F\u7684\u4F1A\u66F4\u5371\u9669\u5417\uFF1F"
      npcReplyLines:
      - "\u6CE8\u610F\u90A3\u4E9B\u5FFD\u7136\u592A\u5B89\u9759\u7684\u5730\u65B9\uFF0C\u5F80\u5F80\u6BD4\u6709\u58F0\u54CD\u7684\u5730\u65B9\u66F4\u503C\u5F97\u7559\u5FC3\u3002"
      - "\u5FEB\u5230\u4F4F\u5904\u65F6\u811A\u6B65\u522B\u4E71\uFF0C\u591C\u91CC\u6700\u4F1A\u62D6\u4F4F\u4EBA\u7684\u5C31\u662F\u90A3\u4E00\u4E0B\u8FDF\u7591\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  phaseInformalChatSets:
  - storyPhase: 70
    conversationBundles:
    - bundleId: 301-return-reminder-resident
      exchanges:
      - exchangeId: exchange-1
        playerLines:
        - "\u56DE\u5C4B\u8FD9\u4E00\u8DEF\u6700\u8BA9\u4F60\u5728\u610F\u7684\uFF0C\u662F\u811A\u6B65\u8FD8\u662F\u90A3\u9635\u8FC7\u5206\u7684\u5B89\u9759\uFF1F"
        - "\u8FD9\u65F6\u5019\u4F60\u8FD8\u5B88\u5728\u540E\u5761\u8FB9\u4E0A\uFF1F"
        npcReplyLines:
        - "\u5148\u662F\u592A\u5B89\u9759\uFF0C\u7136\u540E\u624D\u662F\u811A\u6B65\u4E71\u6389\uFF0C\u5FC3\u865A\u7684\u4EBA\u603B\u7231\u5148\u6536\u58F0\u3002"
        - "\u5B88\u7740\uFF0C\u56DE\u5C4B\u524D\u90A3\u51E0\u6B65\u6700\u5BB9\u6613\u628A\u591C\u91CC\u7684\u614C\u8E29\u51FA\u6765\u3002"
        npcReplyDelayMin: 0.52
        npcReplyDelayMax: 0.86
      completionRelationshipDelta: 1
    walkAwayReaction:
      reactionCue: 301-return-reminder-walkaway
      playerExitLines:
      - "\u6211\u5148\u6CBF\u7740\u56DE\u5C4B\u8FD9\u6BB5\u518D\u542C\u4E00\u5708\u3002"
      - "\u8FD9\u51E0\u6B65\u8DEF\u6700\u4F1A\u628A\u8FDF\u7591\u653E\u5927\u3002"
      npcReactionLines:
      - "\u53BB\u5427\uFF0C\u6211\u5148\u5B88\u7740\u8FD9\u9635\u6536\u58F0\u3002"
      - "\u4F60\u56DE\u6765\u65F6\uFF0C\u811A\u6B65\u91CC\u7684\u614C\u8FD8\u6CA1\u85CF\u597D\u3002"
      relationshipDelta: 0

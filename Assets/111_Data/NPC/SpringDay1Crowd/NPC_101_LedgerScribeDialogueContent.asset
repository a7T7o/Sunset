        - "\u521A\u624D\u56F4\u89C2\u6563\u4E86\u4E00\u70B9\u6CA1\u6709\uFF1F"
        - "\u4ED6\u4EEC\u73B0\u5728\u8FD8\u662F\u4E00\u8FB9\u6446\u644A\u4E00\u8FB9\u5077\u770B\u4F60\u5417\uFF1F"
        npcReplyLines:
        - "\u6563\u662F\u6563\u4E86\uFF0C\u53EF\u62AC\u5934\u7684\u6B21\u6570\u8FD8\u6BD4\u5E73\u65F6\u591A\uFF0C\u6211\u8FD9\u9875\u7EB8\u8FB9\u5168\u8BB0\u7740\u3002"

  m_Script: {fileID: 11500000, guid: 7e1d8fd01cb8442eb570f1fd4d33ac41, type: 3}
  m_Name: NPC_101_ScribeCrowdDialogueContent
  m_EditorClassIdentifier: 
  npcId: 101
  selfTalkLines:
  - "\u8D26\u9875\u7F3A\u53E3\u8D8A\u770B\u8D8A\u5927\uFF0C\u6751\u957F\u8DD1\u5F97\u53EF\u771F\u4F1A\u6311\u65F6\u5019\u3002"
  - "\u6211\u628A\u5370\u7AE0\u7EB9\u6837\u90FD\u6284\u4E0B\u6765\u4E86\uFF0C\u8C01\u60F3\u8D56\u8D26\u90FD\u8D56\u4E0D\u6389\u3002"
  - "\u73B0\u5728\u6751\u91CC\u6700\u6015\u7684\u4E0D\u662F\u4E71\uFF0C\u662F\u6CA1\u4EBA\u80AF\u628A\u5B9E\u8BDD\u843D\u5728\u7EB8\u4E0A\u3002"
  playerNearbyLines:
  - "\u4F60\u4E5F\u662F\u6765\u95EE\u6751\u957F\u90A3\u7B14\u70C2\u8D26\u7684\uFF1F\u6211\u8FD9\u513F\u80FD\u7ED9\u4F60\u4E00\u534A\u7B54\u6848\u3002"
  - "\u522B\u6025\u7740\u7AD9\u961F\uFF0C\u5148\u628A\u8C01\u8BF4\u4E86\u4EC0\u4E48\u8BB0\u6E05\u695A\u3002"
  - "\u4F60\u8981\u662F\u80AF\u5E2E\u5FD9\u9001\u51E0\u9875\u6284\u4EF6\uFF0C\u6211\u8FD9\u8FB9\u4F1A\u5FEB\u5F88\u591A\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 101-ledger-trace
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u4E00\u76F4\u5728\u8BB0\u8D26\uFF0C\u662F\u6015\u6751\u957F\u7559\u4E0B\u7684\u7A9F\u7ABF\u6CA1\u4EBA\u8BA4\u5417\uFF1F"
      - "\u6211\u770B\u4F60\u8FDE\u8FB9\u89D2\u90FD\u6284\u8FDB\u53BB\u4E86\u3002"
      npcReplyLines:
      - "\u4E0D\u662F\u6015\u6CA1\u4EBA\u8BA4\uFF0C\u662F\u6015\u6700\u540E\u6BCF\u4E2A\u4EBA\u90FD\u8BF4\u81EA\u5DF1\u6CA1\u770B\u89C1\u3002"
      - "\u53EA\u8981\u7EB8\u4E0A\u8FD8\u7559\u5F97\u4F4F\u75D5\uFF0C\u9003\u6389\u7684\u4EBA\u5C31\u4E0D\u7B97\u771F\u9003\u5E72\u51C0\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u90A3\u73B0\u5728\u6751\u91CC\u8C01\u6700\u503C\u5F97\u4F60\u4FE1\uFF1F"
      - "\u4F60\u5199\u8FD9\u4E9B\u7684\u65F6\u5019\uFF0C\u5FC3\u91CC\u6709\u6000\u7591\u7684\u4EBA\u5417\uFF1F"
      npcReplyLines:
      - "\u80AF\u628A\u810F\u8BDD\u660E\u7740\u8BF4\u7684\u4EBA\uFF0C\u53CD\u800C\u6BD4\u7B11\u7740\u7CCA\u5F04\u4EBA\u7684\u66F4\u53EF\u4FE1\u3002"
      - "\u6211\u5148\u8BB0\u4E8B\u5B9E\uFF0C\u4FE1\u4EFB\u5F97\u7B49\u98CE\u58F0\u8FC7\u53BB\u518D\u8C08\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: ...
    playerExitLines:
    - "\u6211\u5148\u53BB\u522B\u5904\u95EE\u95EE\uFF0C\u56DE\u5934\u518D\u6765\u627E\u4F60\u3002"
    - "\u4F60\u7EE7\u7EED\u5199\u5427\uFF0C\u6211\u4E0D\u6253\u6270\u3002"
    npcReactionLines:
    - "\u884C\uFF0C\u522B\u5FD8\u4E86\u56DE\u6765\u62FF\u4F60\u90A3\u4E00\u9875\u7B54\u6848\u3002"
    - "\u8981\u662F\u542C\u89C1\u65B0\u6D88\u606F\uFF0C\u8BB0\u5F97\u7B2C\u4E00\u65F6\u95F4\u544A\u8BC9\u6211\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u6751\u91CC\u8FD9\u4E24\u5929\u6700\u503C\u94B1\u7684\u4E0D\u662F\u94B1\uFF0C\u662F\u6709\u4EBA\u80AF\u628A\u8BDD\u8BF4\u660E\u767D\u3002"
  - "\u8001\u8D26\u6CA1\u7ED3\uFF0C\u65B0\u8BDD\u53C8\u6EE1\u8857\u8DD1\uFF0C\u5199\u5B57\u7684\u4EBA\u53CD\u5012\u6700\u5FD9\u3002"
  defaultChatResponderLines:
  - "\u662F\u554A\uFF0C\u6211\u6015\u5927\u5BB6\u8D8A\u4F20\u8D8A\u4E71\uFF0C\u53EA\u597D\u81EA\u5DF1\u4E00\u9875\u9875\u8865\u3002"
  - "\u771F\u76F8\u4E0D\u89C1\u5F97\u597D\u542C\uFF0C\u4F46\u603B\u6BD4\u7A7A\u7740\u5F3A\u3002"
  pairDialogueSets:
  - partnerNpcId: 103
    initiatorLines:
    - "\u4F60\u628A\u90A3\u665A\u770B\u5230\u7684\u80CC\u5F71\u518D\u8BF4\u6162\u4E00\u70B9\uFF0C\u6211\u6015\u6284\u6F0F\u3002"
    - "\u4F60\u8DD1\u5F97\u5FEB\uFF0C\u4F46\u8FD9\u56DE\u5F97\u8BA9\u6BCF\u4E2A\u7EC6\u8282\u90FD\u843D\u5728\u7EB8\u4E0A\u3002"
    responderLines:
    - "\u522B\u6025\uFF0C\u6211\u6B63\u628A\u4F60\u8BF4\u7684\u6B6A\u8116\u6811\u548C\u65AD\u680F\u5199\u5728\u540C\u4E00\u9875\u3002"
    - "\u4F60\u8BB0\u5F97\u8D8A\u51C6\uFF0C\u6751\u957F\u90A3\u6761\u591C\u8DEF\u5C31\u8D8A\u85CF\u4E0D\u4F4F\u3002"
  - partnerNpcId: 104
    initiatorLines:
    - "\u4F60\u8865\u95E8\u7684\u6728\u6599\u6570\u6211\u8BB0\u4E0B\u4E86\uFF0C\u56DE\u5934\u522B\u8BA9\u4EBA\u8BF4\u4E0D\u6E05\u3002"
    - "\u4F60\u90A3\u8FB9\u4FEE\u6805\u680F\u7684\u65F6\u8FB0\uFF0C\u4E5F\u8BB8\u6B63\u597D\u80FD\u5BF9\u4E0A\u6751\u957F\u8DD1\u7684\u65F6\u95F4\u3002"
    responderLines:
    - "\u55EF\uFF0C\u4F60\u5148\u628A\u8D26\u8BB0\u7A33\uFF0C\u574F\u6389\u7684\u95E8\u6211\u8FD9\u8FB9\u4F1A\u4E00\u5757\u5757\u8865\u56DE\u53BB\u3002"
    - "\u53EA\u8981\u4F60\u5199\u5F97\u660E\u767D\uFF0C\u540E\u5934\u8FFD\u8D23\u65F6\u5C31\u4E0D\u4F1A\u53EA\u5269\u5435\u95F9\u3002"
  - partnerNpcId: 203
    initiatorLines:
    - "\u4ECA\u665A\u591A\u71AC\u7684\u90A3\u9505\u4E5F\u8BB0\u4E00\u7B14\uFF0C\u6751\u91CC\u73B0\u5728\u8FDE\u70ED\u6C64\u90FD\u6210\u5B89\u7A33\u4E86\u3002"
    - "\u4F60\u90A3\u8FB9\u8C01\u534A\u591C\u6765\u8BA8\u6C64\uFF0C\u6211\u4E5F\u60F3\u987A\u624B\u8BB0\u4E2A\u540D\u3002"
    responderLines:
    - "\u4F60\u5148\u5199\uFF0C\u6211\u8FD9\u8FB9\u628A\u4EBA\u5582\u9971\u4E86\uFF0C\u5927\u5BB6\u624D\u80AF\u628A\u5B9E\u8BDD\u5410\u51FA\u6765\u3002"
    - "\u771F\u8981\u6709\u4EBA\u591C\u91CC\u614C\u5F97\u7761\u4E0D\u7740\uFF0C\u6700\u540E\u8FD8\u662F\u4F1A\u7AEF\u7740\u7897\u6765\u627E\u6211\u3002"

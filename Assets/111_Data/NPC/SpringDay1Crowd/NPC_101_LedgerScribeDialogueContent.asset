  m_Name: NPC_101_ScribeCrowdDialogueContent
  m_EditorClassIdentifier:
  npcId: 101
  selfTalkLines:
  - "\u4F60\u4E00\u8FDB\u6751\u53E3\uFF0C\u534A\u6761\u8857\u7684\u4EBA\u90FD\u5148\u505C\u4E86\u624B\uFF0C\u6211\u8FD9\u9875\u7EB8\u8FB9\u5230\u73B0\u5728\u8FD8\u538B\u7740\u90A3\u9635\u76EE\u5149\u3002"
  - "\u6709\u4EBA\u8BA9\u5F00\u534A\u6B65\uFF0C\u6709\u4EBA\u53EA\u6562\u9694\u7740\u4EBA\u5806\u5077\u770B\uFF0C\u6211\u5F97\u5148\u628A\u8FD9\u9635\u9759\u8BB0\u6E05\u3002"
  - "\u660E\u65E9\u644A\u5B50\u7167\u6837\u6446\u5F00\uFF0C\u53EF\u4ECA\u5929\u843D\u5728\u4F60\u8EAB\u4E0A\u7684\u90A3\u4E00\u4E0B\u505C\u987F\uFF0C\u4E0D\u8BE5\u5C31\u8FD9\u4E48\u6563\u6389\u3002"
  phaseSelfTalkLines:
  - storyPhase: 20
    selfTalkLines:
    - "\u5148\u628A\u56F4\u89C2\u7684\u773C\u795E\u8BB0\u4E0B\u6765\uFF0C\u7B49\u4ED6\u4EEC\u88C5\u4F5C\u6CA1\u770B\u89C1\u65F6\u624D\u66F4\u597D\u8FA8\u3002"
    - "\u7EB8\u8FB9\u5148\u7559\u8FD9\u4E00\u4E0B\u505C\u987F\uFF0C\u6751\u53E3\u4ECA\u5929\u8C01\u62AC\u5934\u6700\u6162\u6211\u90FD\u770B\u5F97\u89C1\u3002"
  - storyPhase: 60
    selfTalkLines:
    - "\u684C\u8FB9\u8D8A\u88C5\u4F5C\u7167\u5E38\uFF0C\u7B14\u4E0B\u90A3\u70B9\u505C\u987F\u8D8A\u9192\u76EE\u3002"
    - "\u4ECA\u665A\u8FD9\u53E3\u6C14\u4E0D\u80FD\u4E71\u8BB0\uFF0C\u8C01\u5148\u907F\u5F00\u76EE\u5149\u5F97\u5148\u538B\u5728\u9875\u8FB9\u3002"
  - storyPhase: 90
    selfTalkLines:
    - "\u5148\u628A\u4ECA\u665A\u8FD9\u9875\u6536\u597D\uFF0C\u660E\u65E9\u8C01\u88C5\u6CA1\u4E8B\u4E00\u7FFB\u5C31\u77E5\u9053\u3002"
    - "\u7EB8\u5148\u5408\u4E0A\uFF0C\u6751\u53E3\u90A3\u9635\u6CA1\u6563\u6389\u7684\u5B89\u9759\u8FD8\u5F97\u8BB0\u5230\u5929\u4EAE\u3002"
  playerNearbyLines:
  - "\u5148\u522B\u6025\u7740\u95EE\u8DEF\uFF0C\u521A\u624D\u90A3\u9635\u4EBA\u7FA4\u505C\u624B\u770B\u4F60\u7684\u6837\u5B50\uFF0C\u6211\u8FD8\u6CA1\u8BB0\u5B8C\u3002"
  - "\u5B69\u5B50\u4EEC\u90FD\u8EB2\u5728\u4EBA\u540E\u5934\u5077\u770B\uFF0C\u5927\u4EBA\u5012\u53EA\u4F1A\u88C5\u4F5C\u81EA\u5DF1\u624B\u91CC\u8FD8\u6709\u6D3B\u3002"
  - "\u4F60\u8981\u662F\u542C\u89C1\u8C01\u538B\u4F4E\u55D3\u5B50\u8BAE\u8BBA\uFF0C\u8FC7\u6765\u548C\u6211\u5BF9\u4E00\u5BF9\uFF0C\u6211\u6015\u4ED6\u4EEC\u56DE\u5934\u6539\u53E3\u3002"
  relationshipStageNearbyLines: []
  phaseNearbyLines:
  - storyPhase: 20
    playerNearbyLines:
    - "\u6751\u53E3\u8FD9\u4F1A\u513F\u8FD8\u5728\u62FF\u4F59\u5149\u8FFD\u7740\u4F60\uFF0C\u53EA\u662F\u6CA1\u4EBA\u80AF\u5148\u62AC\u5934\u3002"
    - "\u4F60\u518D\u5F80\u524D\u4E24\u6B65\uFF0C\u644A\u8FB9\u90A3\u9635\u505C\u987F\u53C8\u4F1A\u6162\u6162\u6D6E\u51FA\u6765\u3002"
  - storyPhase: 60
    playerNearbyLines:
    - "\u665A\u996D\u90A3\u9635\u8FC7\u53BB\u4E86\uFF0C\u684C\u8FB9\u7684\u8BDD\u66F4\u8F7B\uFF0C\u773C\u795E\u5012\u6CA1\u5C11\u3002"
    - "\u8C01\u5634\u4E0A\u8BF4\u7167\u5E38\uFF0C\u624B\u4E0A\u7684\u52A8\u4F5C\u53CD\u800C\u66F4\u5BB9\u6613\u6162\u534A\u62CD\u3002"
  - storyPhase: 90
    playerNearbyLines:
    - "\u5929\u8272\u6536\u4E0B\u53BB\u540E\uFF0C\u7EB8\u8FB9\u8FD8\u538B\u7740\u4ECA\u665A\u90A3\u9635\u6CA1\u6563\u6389\u7684\u5B89\u9759\u3002"
    - "\u660E\u65E9\u644A\u5B50\u4F1A\u7167\u5E38\u6446\u5F00\uFF0C\u4F46\u4ECA\u665A\u8FD9\u53E3\u6C14\u8FD8\u5728\u6751\u53E3\u6253\u8F6C\u3002"
  defaultInformalConversationBundles:
  - bundleId: 101-ledger-trace
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u4E00\u76F4\u5728\u8BB0\u8D26\uFF0C\u662F\u6015\u6751\u957F\u7559\u4E0B\u7684\u7A9F\u7ABF\u6CA1\u4EBA\u8BA4\u5417\uFF1F"
      - "\u6211\u770B\u4F60\u8FDE\u8FB9\u89D2\u90FD\u6284\u8FDB\u53BB\u4E86\u3002"
      npcReplyLines:
      - "\u4E0D\u662F\u6015\u6CA1\u4EBA\u8BA4\uFF0C\u662F\u6015\u6700\u540E\u6BCF\u4E2A\u4EBA\u90FD\u8BF4\u81EA\u5DF1\u6CA1\u770B\u89C1\u3002"
      - "\u53EA\u8981\u7EB8\u4E0A\u8FD8\u7559\u5F97\u4F4F\u75D5\uFF0C\u9003\u6389\u7684\u4EBA\u5C31\u4E0D\u7B97\u771F\u9003\u5E72\u51C0\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u90A3\u73B0\u5728\u6751\u91CC\u8C01\u6700\u503C\u5F97\u4F60\u4FE1\uFF1F"
      - "\u4F60\u5199\u8FD9\u4E9B\u7684\u65F6\u5019\uFF0C\u5FC3\u91CC\u6709\u6000\u7591\u7684\u4EBA\u5417\uFF1F"
      npcReplyLines:
      - "\u80AF\u628A\u810F\u8BDD\u660E\u7740\u8BF4\u7684\u4EBA\uFF0C\u53CD\u800C\u6BD4\u7B11\u7740\u7CCA\u5F04\u4EBA\u7684\u66F4\u53EF\u4FE1\u3002"
      - "\u6211\u5148\u8BB0\u4E8B\u5B9E\uFF0C\u4FE1\u4EFB\u5F97\u7B49\u98CE\u58F0\u8FC7\u53BB\u518D\u8C08\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  phaseInformalChatSets:

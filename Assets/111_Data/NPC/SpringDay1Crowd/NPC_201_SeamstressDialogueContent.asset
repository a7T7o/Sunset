  m_Script: {fileID: 11500000, guid: 7e1d8fd01cb8442eb570f1fd4d33ac41, type: 3}
  m_Name: NPC_201_SeamstressDialogueContent
  m_EditorClassIdentifier: 
  npcId: 201
  selfTalkLines:
  - "\u8863\u89D2\u88C2\u4E86\u8FD8\u80FD\u8865\uFF0C\u5FC3\u91CC\u90A3\u9053\u53E3\u5B50\u5C31\u96BE\u8BF4\u4E86\u3002"
  - "\u6751\u957F\u8DD1\u540E\uFF0C\u6765\u627E\u6211\u7F1D\u5E03\u888B\u7684\u4EBA\u4E00\u4E0B\u591A\u4E86\u4E09\u6210\u3002"
  - "\u5927\u5BB6\u5634\u4E0A\u8BF4\u6CA1\u4E8B\uFF0C\u624B\u5374\u90FD\u5728\u53D1\u6296\u3002"
  playerNearbyLines:
  - "\u4F60\u8138\u8272\u8FD8\u6CA1\u5B8C\u5168\u7F13\u8FC7\u6765\uFF0C\u5148\u522B\u786C\u6491\u3002"
  - "\u8981\u662F\u8896\u53E3\u78E8\u7834\u4E86\uFF0C\u6765\u6211\u8FD9\u513F\u5750\u5750\uFF0C\u6211\u987A\u624B\u7ED9\u4F60\u7F1D\u4E0A\u3002"
  - "\u6700\u8FD1\u5927\u5BB6\u90FD\u7761\u5F97\u6D45\uFF0C\u4F60\u4E5F\u522B\u8BA9\u81EA\u5DF1\u592A\u7D2F\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 201-seam-breath
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u770B\u8D77\u6765\u6BD4\u522B\u4EBA\u9547\u5B9A\u5F97\u591A\u3002"
      - "\u662F\u4E0D\u662F\u5F88\u591A\u4EBA\u90FD\u6765\u627E\u4F60\u8BF4\u8BDD\uFF1F"
      npcReplyLines:
      - "\u6765\u7684\u4EBA\u591A\uFF0C\u614C\u7684\u4EBA\u66F4\u591A\uFF0C\u6211\u603B\u5F97\u5148\u7A33\u4F4F\u81EA\u5DF1\u3002"
      - "\u7F1D\u8863\u670D\u65F6\u9488\u811A\u4E0D\u80FD\u4E71\uFF0C\u5B89\u6170\u4EBA\u4E5F\u5DEE\u4E0D\u591A\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u6751\u957F\u8DD1\u4E86\u4E4B\u540E\uFF0C\u4F60\u6700\u62C5\u5FC3\u4EC0\u4E48\uFF1F"
      - "\u4F60\u5FC3\u91CC\u4E5F\u4F1A\u6CA1\u5E95\u5417\uFF1F"
      npcReplyLines:
      - "\u62C5\u5FC3\u5927\u5BB6\u5634\u4E0A\u901E\u5F3A\uFF0C\u591C\u91CC\u5374\u4E00\u4E2A\u4E2A\u7761\u4E0D\u7740\u3002"
      - "\u6CA1\u5E95\u5F53\u7136\u4F1A\u6709\uFF0C\u4F46\u53EA\u8981\u8FD8\u6709\u4EBA\u613F\u610F\u4E92\u76F8\u7167\u5E94\uFF0C\u5C31\u6CA1\u5230\u6563\u7684\u65F6\u5019\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: "\u597D\u5427"
    playerExitLines:
    - "\u6211\u5148\u53BB\u524D\u9762\u8F6C\u8F6C\u3002"
    - "\u4F60\u7EE7\u7EED\u5FD9\u4F60\u7684\u9488\u7EBF\u3002"
    npcReactionLines:
    - "\u53BB\u5427\uFF0C\u56DE\u6765\u65F6\u8981\u662F\u624B\u5957\u78E8\u574F\u4E86\uFF0C\u62FF\u6765\u7ED9\u6211\u770B\u770B\u3002"
    - "\u522B\u5FD8\u4E86\u4ECA\u665A\u65E9\u70B9\u6B47\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u6211\u6700\u64C5\u957F\u7684\u4E0D\u662F\u7F1D\u7EBF\uFF0C\u662F\u8BA9\u4EBA\u5750\u4E0B\u540E\u6162\u6162\u628A\u6C14\u5598\u5300\u3002"
  - "\u6709\u4EBA\u9003\u4E86\uFF0C\u6709\u4EBA\u5C31\u5F97\u7559\u4E0B\u6765\u628A\u6563\u6389\u7684\u5730\u65B9\u7F1D\u8D77\u6765\u3002"
  defaultChatResponderLines:
  - "\u662F\u5440\uFF0C\u5148\u628A\u9488\u811A\u843D\u7A33\uFF0C\u5FC3\u624D\u4E0D\u4F1A\u8DDF\u7740\u6563\u3002"
  - "\u8981\u662F\u4F60\u4E5F\u89C9\u5F97\u614C\uFF0C\u5C31\u5148\u5728\u6211\u65C1\u8FB9\u7AD9\u4E00\u4F1A\u513F\u3002"
  pairDialogueSets:
  - partnerNpcId: 202
    initiatorLines:
    - "\u6843\u7FBD\uFF0C\u628A\u5B89\u795E\u8349\u624E\u7D27\u4E9B\uFF0C\u4ECA\u665A\u6765\u627E\u6211\u7684\u624B\u90FD\u5728\u6296\u3002"
    - "\u4F60\u90A3\u675F\u4EAE\u8272\u4E00\u6446\u4E0A\u53BB\uFF0C\u4EBA\u5750\u4E0B\u65F6\u6C14\u5C31\u987A\u591A\u4E86\u3002"
    responderLines:
    - "\u6211\u77E5\u9053\uFF0C\u6240\u4EE5\u6211\u624D\u4E0D\u80AF\u8BA9\u5E97\u91CC\u53EA\u5269\u7070\u6251\u6251\u7684\u5E03\u8272\u3002"
    - "\u4F60\u7F1D\u4F4F\u5927\u5BB6\u7684\u8896\u53E3\uFF0C\u6211\u6765\u66FF\u4ED6\u4EEC\u7559\u4E00\u70B9\u80AF\u62AC\u5934\u7684\u5FC3\u60C5\u3002"

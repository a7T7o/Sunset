    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  phaseInformalChatSets:
  - storyPhase: 30
    conversationBundles:
    - bundleId: 201-healing-resident
      exchanges:
      - exchangeId: exchange-1
        playerLines:
        - "\u7597\u4F24\u8FD9\u9635\u4E4B\u540E\uFF0C\u6765\u627E\u4F60\u7684\u4EBA\u662F\u4E0D\u662F\u66F4\u591A\u4E86\uFF1F"
        - "\u5927\u5BB6\u5634\u4E0A\u4E0D\u8BF4\uFF0C\u8138\u8272\u4F60\u90FD\u770B\u51FA\u6765\u4E86\u5427\uFF1F"
        npcReplyLines:
        - "\u55EF\uFF0C\u8D8A\u8BF4\u6CA1\u4E8B\u7684\u4EBA\uFF0C\u5750\u4E0B\u65F6\u8D8A\u4F1A\u5148\u634F\u4F4F\u8896\u53E3\u3002"

  m_Name: NPC_202_HerbCrowdDialogueContent
  m_EditorClassIdentifier:
  npcId: 202
  selfTalkLines:
  - "\u665A\u996D\u90A3\u9635\u706B\u6C14\u592A\u91CD\uFF0C\u6211\u5C31\u628A\u5B89\u795E\u8349\u591A\u624E\u4E86\u51E0\u675F\u6302\u5728\u95E8\u8FB9\u3002"
  - "\u6709\u4EBA\u5634\u4E0A\u8BF4\u4E0D\u7528\uFF0C\u624B\u5374\u4F1A\u5728\u82B1\u675F\u8FB9\u505C\u4E00\u4E0B\uFF0C\u50CF\u6015\u628A\u591C\u91CC\u7684\u614C\u5E26\u56DE\u5C4B\u3002"
  - "\u660E\u65E9\u644A\u5B50\u8FD8\u662F\u7167\u5E38\u6446\uFF0C\u6211\u53EF\u4E0D\u60F3\u8BA9\u6751\u91CC\u53EA\u5269\u4E00\u8138\u7070\u8272\u3002"
  phaseSelfTalkLines:
  - storyPhase: 50
    selfTalkLines:
    - "\u5148\u7559\u4E00\u70B9\u989C\u8272\uFF0C\u522B\u8BA9\u5FD9\u51FA\u6765\u7684\u7070\u6C14\u8DDF\u7740\u56DE\u5C4B\u3002"
    - "\u5B89\u795E\u8349\u4E0D\u5435\uFF0C\u53EF\u8FD9\u4F1A\u513F\u6B63\u597D\u80FD\u628A\u4EBA\u62C9\u56DE\u4E00\u70B9\u3002"
  - storyPhase: 70
    selfTalkLines:
    - "\u56DE\u5C4B\u524D\u5148\u95FB\u4E00\u95FB\uFF0C\u811A\u6B65\u522B\u8BA9\u591C\u8272\u50AC\u5F97\u592A\u6025\u3002"
    - "\u95E8\u8FB9\u8FD9\u70B9\u9999\u5148\u7559\u7740\uFF0C\u514D\u5F97\u4E00\u8F6C\u8EAB\u773C\u91CC\u53EA\u5269\u7070\u3002"
  - storyPhase: 90
    selfTalkLines:
    - "\u82B1\u5148\u522B\u6536\uFF0C\u591C\u91CC\u603B\u5F97\u7559\u4E00\u70B9\u4E0D\u53D1\u786C\u7684\u4EAE\u8272\u3002"
    - "\u660E\u65E9\u7167\u5E38\u6446\u51FA\u6765\uFF0C\u6751\u91CC\u624D\u4E0D\u4F1A\u53EA\u5269\u6628\u665A\u90A3\u80A1\u706B\u6C14\u3002"
  playerNearbyLines:
  - "\u56DE\u5C4B\u524D\u62FF\u4E00\u5C0F\u675F\u4E5F\u597D\uFF0C\u4ECA\u665A\u5927\u5BB6\u95FB\u89C1\u7684\u706B\u836F\u5473\u5DF2\u7ECF\u591F\u591A\u4E86\u3002"
  - "\u522B\u6015\u6211\u8BF4\u6F02\u4EAE\u8BDD\uFF0C\u771F\u5230\u4E86\u6563\u573A\u65F6\uFF0C\u603B\u5F97\u6709\u4EBA\u66FF\u5927\u5BB6\u7559\u4E00\u70B9\u80FD\u5598\u53E3\u6C14\u7684\u989C\u8272\u3002"
  - "\u5929\u4EAE\u540E\u82B1\u8FD8\u5F97\u7167\u5E38\u5F00\uFF0C\u4EBA\u4E5F\u5F97\u7167\u5E38\u62AC\u5934\uFF0C\u4E0D\u7136\u90A3\u4EBA\u624D\u7B97\u771F\u628A\u6751\u91CC\u5413\u4F4F\u4E86\u3002"
  relationshipStageNearbyLines: []
  phaseNearbyLines:
  - storyPhase: 50
    playerNearbyLines:
    - "\u5FD9\u5B8C\u624B\u4E0A\u7684\u6D3B\u4E5F\u5E26\u4E00\u675F\u5B89\u795E\u8349\u5427\uFF0C\u522B\u8BA9\u614C\u52B2\u8DDF\u7740\u4F60\u56DE\u5C4B\u3002"
    - "\u4ECA\u665A\u706B\u6C14\u592A\u91CD\u4E86\uFF0C\u603B\u5F97\u7559\u70B9\u989C\u8272\u628A\u4EBA\u62C9\u56DE\u6765\u3002"
  - storyPhase: 70
    playerNearbyLines:
    - "\u56DE\u5C4B\u63D0\u9192\u5F52\u63D0\u9192\uFF0C\u771F\u80FD\u8BA9\u4EBA\u7F13\u53E3\u6C14\u7684\u8FD8\u662F\u95E8\u8FB9\u8FD9\u70B9\u9999\u3002"
    - "\u8FD9\u4F1A\u513F\u5927\u5BB6\u6700\u6015\u7684\u4E0D\u662F\u9ED1\uFF0C\u662F\u4E00\u56DE\u5934\u773C\u91CC\u53EA\u5269\u7070\u8272\u3002"
  - storyPhase: 90
    playerNearbyLines:
    - "\u660E\u65E9\u82B1\u8FD8\u662F\u7167\u5E38\u5F00\uFF0C\u4EBA\u4E5F\u5F97\u7167\u5E38\u62AC\u5934\u3002"
    - "\u6751\u91CC\u60F3\u6491\u4F4F\uFF0C\u5C31\u4E0D\u80FD\u8BA9\u591C\u91CC\u7684\u614C\u628A\u989C\u8272\u5168\u62BD\u5E72\u3002"
  defaultInformalConversationBundles:
  - bundleId: 202-bloom-keep
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u600E\u4E48\u8FD8\u6709\u5FC3\u60C5\u6574\u7406\u82B1\u675F\uFF1F"
      - "\u5927\u5BB6\u90FD\u5728\u62C5\u5FC3\u7684\u65F6\u5019\uFF0C\u4F60\u8FD9\u513F\u53CD\u800C\u6700\u4EAE\u3002"

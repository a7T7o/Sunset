  m_Name: NPC_202_HerbCrowdDialogueContent
  m_EditorClassIdentifier: 
  npcId: 202
  selfTalkLines:
  - "\u6211\u628A\u5B89\u795E\u8349\u548C\u5C0F\u767D\u82B1\u624E\u5728\u4E00\u8D77\uFF0C\u95FB\u8D77\u6765\u5C31\u6CA1\u90A3\u4E48\u82E6\u3002"
  - "\u6751\u957F\u8DD1\u4E86\u4E5F\u597D\uFF0C\u81F3\u5C11\u4EE5\u540E\u6CA1\u4EBA\u62FF\u82B1\u675F\u88C5\u4F53\u9762\u4E86\u3002"
  - "\u53EA\u8981\u82B1\u8FD8\u5F00\u7740\uFF0C\u6751\u91CC\u5C31\u4E0D\u8BE5\u53EA\u5269\u6101\u7709\u82E6\u8138\u3002"
  playerNearbyLines:
  - "\u4F60\u8981\u4E0D\u8981\u5E26\u4E00\u5C0F\u675F\u82B1\u56DE\u53BB\uFF1F\u5C31\u5F53\u7ED9\u4ECA\u5929\u538B\u538B\u60CA\u3002"
  - "\u522B\u603B\u76EF\u7740\u574F\u6D88\u606F\u770B\uFF0C\u773C\u775B\u4F1A\u8D8A\u770B\u8D8A\u7070\u3002"
  - "\u6211\u77E5\u9053\u73B0\u5728\u4E0D\u592A\u50CF\u8BF4\u6F02\u4EAE\u8BDD\u7684\u65F6\u5019\uFF0C\u53EF\u4EBA\u8FD8\u662F\u5F97\u5148\u62AC\u8D77\u5934\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 202-bloom-keep
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u600E\u4E48\u8FD8\u6709\u5FC3\u60C5\u6574\u7406\u82B1\u675F\uFF1F"
      - "\u5927\u5BB6\u90FD\u5728\u62C5\u5FC3\u7684\u65F6\u5019\uFF0C\u4F60\u8FD9\u513F\u53CD\u800C\u6700\u4EAE\u3002"
      npcReplyLines:
      - "\u8D8A\u4E71\u7684\u65F6\u5019\u8D8A\u8981\u6709\u4EBA\u7559\u4E00\u70B9\u4EAE\u8272\uFF0C\u4E0D\u7136\u5FC3\u4F1A\u5148\u584C\u6389\u3002"
      - "\u82B1\u4E0D\u4F1A\u66FF\u4EBA\u89E3\u51B3\u4E8B\uFF0C\u4F46\u5B83\u80FD\u8BA9\u4EBA\u8BB0\u5F97\u81EA\u5DF1\u8FD8\u6D3B\u7740\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u8FD9\u4E9B\u82B1\u662F\u7ED9\u8C01\u51C6\u5907\u7684\uFF1F"
      - "\u662F\u4E0D\u662F\u5F88\u591A\u4EBA\u6765\u627E\u4F60\u62FF\u5B89\u795E\u8349\uFF1F"
      npcReplyLines:
      - "\u7ED9\u8C01\u90FD\u884C\uFF0C\u7761\u4E0D\u7740\u7684\u4EBA\u3001\u5B88\u591C\u7684\u4EBA\u3001\u60F3\u88C5\u9547\u5B9A\u7684\u4EBA\u90FD\u9700\u8981\u3002"
      - "\u6211\u53EA\u662F\u4E0D\u60F3\u8BA9\u5927\u5BB6\u4E00\u56DE\u5934\uFF0C\u770B\u5230\u7684\u5168\u662F\u9003\u8DD1\u7559\u4E0B\u7684\u7A7A\u767D\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: "\u5440"
    playerExitLines:
    - "\u6211\u5148\u53BB\u522B\u5904\u770B\u770B\u3002"
    - "\u56DE\u5934\u518D\u6765\u95FB\u4F60\u7684\u82B1\u3002"
    npcReactionLines:
    - "\u597D\u5440\uFF0C\u56DE\u6765\u65F6\u6211\u7ED9\u4F60\u6311\u4E00\u675F\u4E0D\u624E\u624B\u7684\u3002"
    - "\u522B\u8D70\u592A\u6025\uFF0C\u82B1\u9999\u8DDF\u4E0D\u4E0A\u4F60\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u6211\u8BA8\u538C\u518D\u5FCD\u5FCD\u5C31\u597D\u8FD9\u79CD\u8BDD\uFF0C\u6240\u4EE5\u53EA\u7ED9\u4EBA\u80FD\u95FB\u5230\u7684\u5B89\u7A33\u3002"
  - "\u82B1\u5F00\u5F97\u8D8A\u4EAE\uFF0C\u6211\u8D8A\u89C9\u5F97\u90A3\u4E2A\u4EBA\u8DD1\u5F97\u5FC3\u865A\u3002"
  defaultChatResponderLines:
  - "\u55EF\uFF0C\u6211\u5C31\u662F\u4E0D\u60F3\u8BA9\u6751\u91CC\u4E00\u591C\u4E4B\u95F4\u53EA\u5269\u571F\u8272\u3002"
  - "\u771F\u8981\u6709\u4EBA\u6015\u9ED1\uFF0C\u6211\u5C31\u5148\u628A\u8FD9\u70B9\u4EAE\u8272\u5B88\u4F4F\u3002"
  pairDialogueSets:
  - partnerNpcId: 201
    initiatorLines:
    - "\u6211\u53C8\u914D\u4E86\u4E24\u675F\u4E0D\u90A3\u4E48\u82E6\u7684\u5B89\u795E\u8349\uFF0C\u4F60\u66FF\u6211\u5206\u7ED9\u7761\u4E0D\u7740\u7684\u4EBA\u3002"
    - "\u8981\u662F\u6709\u4EBA\u5634\u786C\u4E0D\u80AF\u62FF\uFF0C\u4F60\u5C31\u8BF4\u662F\u6211\u786C\u585E\u7684\u3002"
    responderLines:
    - "\u597D\uFF0C\u6211\u4E00\u8FB9\u7F1D\u4E00\u8FB9\u66FF\u4F60\u529D\uFF0C\u603B\u6709\u4EBA\u4F1A\u80AF\u4F38\u624B\u63A5\u3002"
    - "\u4F60\u8FD9\u70B9\u4EAE\u8272\u548C\u9999\u6C14\uFF0C\u6700\u8FD1\u6BD4\u7A7A\u53E3\u5B89\u6170\u7BA1\u7528\u591A\u4E86\u3002"

  m_Script: {fileID: 11500000, guid: 7e1d8fd01cb8442eb570f1fd4d33ac41, type: 3}
  m_Name: NPC_103_ErrandBoyDialogueContent
  m_EditorClassIdentifier: 
  npcId: 103
  selfTalkLines:
  - "\u6211\u90A3\u665A\u771F\u770B\u5230\u4ED6\u62AB\u7740\u5916\u5957\u5F80\u540E\u5761\u8DD1\uFF0C\u4E0D\u662F\u773C\u82B1\u3002"
  - "\u5927\u5BB6\u90FD\u8BA9\u6211\u5C11\u8BF4\uFF0C\u53EF\u6211\u618B\u7740\u53C8\u96BE\u53D7\u3002"
  - "\u73B0\u5728\u8FDE\u9001\u5C01\u53E3\u4FE1\u7684\u4EBA\u90FD\u627E\u4E0D\u5230\uFF0C\u6D3B\u5168\u538B\u5230\u6211\u5934\u4E0A\u4E86\u3002"
  playerNearbyLines:
  - "\u4F60\u662F\u4E0D\u662F\u4E5F\u60F3\u95EE\u6751\u957F\u8DD1\u90A3\u665A\u7684\u4E8B\uFF1F\u6211\u8BB0\u5F97\u53EF\u6E05\u695A\u4E86\u3002"
  - "\u522B\u542C\u90A3\u4E9B\u5927\u4EBA\u88C5\u9547\u5B9A\uFF0C\u4ED6\u4EEC\u6BD4\u6211\u8FD8\u614C\u3002"
  - "\u8981\u662F\u4F60\u53BB\u540E\u5761\uFF0C\u8BB0\u5F97\u770B\u90A3\u68F5\u6B6A\u8116\u6811\u65C1\u8FB9\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 103-night-back
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u771F\u770B\u89C1\u6751\u957F\u8DD1\u4E86\uFF1F"
      - "\u90A3\u665A\u5230\u5E95\u662F\u4EC0\u4E48\u6837\uFF1F"
      npcReplyLines:
      - "\u771F\u7684\uFF0C\u4ED6\u6CA1\u56DE\u5934\uFF0C\u4E00\u8DEF\u62B1\u7740\u4E1C\u897F\u5F80\u9ED1\u91CC\u94BB\u3002"
      - "\u6211\u8FD8\u542C\u89C1\u4ED6\u8E29\u65AD\u4E86\u4E00\u622A\u6728\u680F\uFF0C\u50CF\u6025\u5F97\u6015\u88AB\u8C01\u8FFD\u4E0A\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u4F60\u4E3A\u4EC0\u4E48\u8FD8\u6562\u628A\u8FD9\u4E8B\u8BF4\u51FA\u6765\uFF1F"
      - "\u6362\u522B\u4EBA\u65E9\u5C31\u95ED\u5634\u4E86\u5427\u3002"
      npcReplyLines:
      - "\u56E0\u4E3A\u6211\u6015\u518D\u665A\u4E00\u70B9\uFF0C\u8FDE\u6211\u81EA\u5DF1\u90FD\u4F1A\u6000\u7591\u90A3\u665A\u662F\u4E0D\u662F\u771F\u7684\u3002"
      - "\u603B\u5F97\u6709\u4EBA\u628A\u7B2C\u4E00\u773C\u770B\u5230\u7684\u6837\u5B50\u7559\u4F4F\uFF0C\u4E0D\u7136\u5927\u5BB6\u53EA\u4F1A\u8D8A\u8BB2\u8D8A\u5047\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: "\u6B38"
    playerExitLines:
    - "\u6211\u5148\u8D70\u5566\uFF0C\u56DE\u5934\u518D\u542C\u4F60\u8BF4\u3002"
    - "\u4F60\u7EE7\u7EED\u5FD9\u4F60\u7684\uFF0C\u6211\u4E0D\u803D\u8BEF\u4F60\u3002"
    npcReactionLines:
    - "\u597D\uFF0C\u90A3\u4F60\u56DE\u6765\u65F6\u522B\u88C5\u4E0D\u8BA4\u8BC6\u6211\u3002"
    - "\u6211\u8FD9\u8FB9\u8981\u662F\u53C8\u60F3\u8D77\u7EC6\u8282\uFF0C\u4F1A\u7B2C\u4E00\u65F6\u95F4\u544A\u8BC9\u4F60\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u6211\u73B0\u5728\u8DD1\u817F\u90FD\u5F97\u7ED5\u8DEF\uFF0C\u8C01\u77E5\u9053\u4F1A\u4E0D\u4F1A\u649E\u4E0A\u602A\u4E1C\u897F\u3002"
  - "\u6751\u91CC\u8BDD\u8D8A\u591A\uFF0C\u6211\u8D8A\u6015\u81EA\u5DF1\u54EA\u53E5\u8BF4\u6162\u4E86\u3002"
  defaultChatResponderLines:
  - "\u6211\u77E5\u9053\uFF0C\u6211\u5634\u5FEB\uFF0C\u4F46\u603B\u5F97\u6709\u4EBA\u628A\u771F\u770B\u5230\u7684\u8BF4\u51FA\u6765\u3002"
  - "\u8981\u4E0D\u662F\u6211\u8BB0\u5F97\u90A3\u80CC\u5F71\uFF0C\u5927\u5BB6\u8FD8\u4EE5\u4E3A\u6751\u957F\u662F\u51ED\u7A7A\u6CA1\u7684\u3002"
  pairDialogueSets:
  - partnerNpcId: 101
    initiatorLines:
    - "\u83B1\u672D\uFF0C\u6211\u53C8\u60F3\u8D77\u4E00\u70B9\uFF0C\u90A3\u4EBA\u7FFB\u8FC7\u680F\u7684\u65F6\u5019\u5916\u5957\u89D2\u662F\u6E7F\u7684\u3002"
    - "\u4F60\u5FEB\u8BB0\uFF0C\u6211\u6015\u5F85\u4F1A\u513F\u53C8\u88AB\u522B\u4EBA\u6253\u5C94\u3002"
    responderLines:
    - "\u6211\u8BB0\u7740\u5462\uFF0C\u4F60\u53EA\u7BA1\u628A\u5148\u540E\u987A\u5E8F\u8BF4\u6E05\u3002"
    - "\u4F60\u60F3\u5230\u4E00\u70B9\uFF0C\u6211\u8FD9\u8FB9\u5C31\u80FD\u628A\u90A3\u665A\u8865\u5B8C\u6574\u4E00\u70B9\u3002"
  - partnerNpcId: 104
    initiatorLines:
    - "\u6C88\u65A7\u53D4\uFF0C\u65AD\u6389\u7684\u90A3\u622A\u6728\u680F\u662F\u4E0D\u662F\u4F60\u540E\u6765\u53BB\u8865\u7684\uFF1F"
    - "\u6211\u90A3\u665A\u542C\u89C1\u4E00\u58F0\u8106\u54CD\uFF0C\u5E94\u8BE5\u5C31\u662F\u90A3\u513F\u3002"
    responderLines:
    - "\u5BF9\uFF0C\u90A3\u9053\u53E3\u5B50\u6211\u4E00\u770B\u5C31\u77E5\u9053\u4E0D\u662F\u98CE\u522E\u7684\u3002"
    - "\u4F60\u8BB0\u4F4F\u54CD\u58F0\u7684\u4F4D\u7F6E\uFF0C\u6211\u8FD9\u8FB9\u5C31\u80FD\u628A\u7F3A\u53E3\u5BF9\u4E0A\u3002"
  - partnerNpcId: 203
    initiatorLines:
    - "\u9EA6\u79BE\u59D0\uFF0C\u90A3\u665A\u6211\u8DD1\u56DE\u6751\u65F6\u95FB\u89C1\u4F60\u90A3\u8FB9\u8FD8\u5728\u71AC\u6C64\u3002"
    - "\u6211\u672C\u6765\u60F3\u558A\u4EBA\uFF0C\u7ED3\u679C\u5148\u88AB\u90A3\u80A1\u70ED\u6C14\u7ECA\u4F4F\u4E86\u3002"
    responderLines:
    - "\u5148\u522B\u5149\u987E\u7740\u95FB\u6C64\u5473\uFF0C\u628A\u4F60\u770B\u5230\u7684\u4EBA\u5F71\u987A\u7740\u8BF4\u4E00\u904D\u3002"
    - "\u4F60\u8981\u662F\u53C8\u60F3\u8D77\u7EC6\u8282\uFF0C\u6765\u6211\u8FD9\u513F\u8FB9\u559D\u8FB9\u8BB2\u4E5F\u884C\u3002"

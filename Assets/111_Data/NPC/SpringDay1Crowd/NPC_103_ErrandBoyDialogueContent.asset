  - partnerNpcId: 101
    initiatorLines:
    - "\u6211\u53C8\u60F3\u8D77\u4E00\u70B9\uFF0C\u521A\u624D\u6751\u53E3\u90A3\u7FA4\u4EBA\u662F\u5047\u88C5\u5FD9\uFF0C\u5176\u5B9E\u5168\u5728\u5077\u770B\u4F60\u3002"
    - "\u4F60\u5FEB\u8BB0\uFF0C\u8C01\u5148\u8BA9\u5F00\u534A\u6B65\u3001\u8C01\u53EA\u6562\u4ECE\u95E8\u7F1D\u91CC\u770B\uFF0C\u6211\u90FD\u77A7\u89C1\u4E86\u3002"
    responderLines:
    - "\u6211\u8BB0\u7740\u5462\uFF0C\u4F60\u628A\u90A3\u9635\u505C\u624B\u7684\u5148\u540E\u8BF4\u6E05\uFF0C\u6211\u8FD9\u8FB9\u5C31\u80FD\u8865\u5168\u3002"
    - "\u7B49\u660E\u65E9\u4ED6\u4EEC\u53C8\u7167\u5E38\u7AD9\u597D\uFF0C\u8FD9\u4E00\u665A\u8C01\u5077\u770B\u5F97\u6700\u4E45\u6211\u4E5F\u8BA4\u5F97\u51FA\u6765\u3002"
  - partnerNpcId: 104
    initiatorLines:
    - "\u65AD\u6389\u7684\u90A3\u622A\u6728\u680F\u662F\u4E0D\u662F\u4F60\u540E\u6765\u53BB\u8865\u7684\uFF1F"
    - "\u6211\u90A3\u665A\u542C\u89C1\u4E00\u58F0\u8106\u54CD\uFF0C\u5E94\u8BE5\u5C31\u662F\u90A3\u513F\u3002"
    responderLines:
    - "\u5BF9\uFF0C\u90A3\u9053\u53E3\u5B50\u6211\u4E00\u770B\u5C31\u77E5\u9053\u4E0D\u662F\u98CE\u522E\u7684\u3002"
    - "\u4F60\u8BB0\u4F4F\u54CD\u58F0\u7684\u4F4D\u7F6E\uFF0C\u6211\u8FD9\u8FB9\u5C31\u80FD\u628A\u7F3A\u53E3\u5BF9\u4E0A\u3002"
  - partnerNpcId: 203
    initiatorLines:
    - "\u90A3\u665A\u6211\u8DD1\u56DE\u6751\u65F6\u95FB\u89C1\u4F60\u90A3\u8FB9\u8FD8\u5728\u71AC\u6C64\u3002"
    - "\u6211\u672C\u6765\u60F3\u558A\u4EBA\uFF0C\u7ED3\u679C\u5148\u770B\u89C1\u684C\u8FB9\u90A3\u5708\u4EBA\u90FD\u538B\u4F4E\u4E86\u58F0\u3002"
    responderLines:
    - "\u5148\u522B\u5149\u987E\u7740\u95FB\u6C64\u5473\uFF0C\u628A\u4F60\u770B\u5230\u7684\u4EBA\u5F71\u987A\u7740\u8BF4\u4E00\u904D\u3002"
    - "\u4F60\u8981\u662F\u53C8\u60F3\u8D77\u7EC6\u8282\uFF0C\u6765\u6211\u8FD9\u513F\u8FB9\u559D\u8FB9\u8BB2\u4E5F\u884C\u3002"

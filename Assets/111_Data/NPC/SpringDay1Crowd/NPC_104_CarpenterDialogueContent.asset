  m_Script: {fileID: 11500000, guid: 7e1d8fd01cb8442eb570f1fd4d33ac41, type: 3}
  m_Name: NPC_104_CarpenterDialogueContent
  m_EditorClassIdentifier: 
  npcId: 104
  selfTalkLines:
  - "\u95E8\u6813\u5F97\u518D\u52A0\u4E00\u9053\uFF0C\u6751\u957F\u8DD1\u4E86\uFF0C\u80C6\u5C0F\u9B3C\u4E5F\u4F1A\u8DDF\u7740\u591A\u8D77\u6765\u3002"
  - "\u574F\u7684\u662F\u4EBA\u5FC3\u5148\uFF0C\u6728\u5934\u53CD\u5012\u597D\u4FEE\u3002"
  - "\u8FD9\u6751\u5B50\u8981\u6491\u4F4F\uFF0C\u9760\u7684\u4E0D\u662F\u558A\u8BDD\uFF0C\u662F\u4E00\u9524\u4E00\u9524\u8865\u56DE\u53BB\u3002"
  playerNearbyLines:
  - "\u770B\u4F60\u50CF\u4E2A\u80FD\u642D\u628A\u624B\u7684\u4EBA\uFF0C\u6709\u7A7A\u5C31\u66FF\u6211\u642C\u4E24\u5757\u677F\u3002"
  - "\u522B\u62C5\u5FC3\uFF0C\u6211\u8FD9\u8FB9\u505A\u7684\u90FD\u662F\u8BA9\u591C\u91CC\u80FD\u7761\u7740\u7684\u6D3B\u3002"
  - "\u8981\u662F\u4F60\u4ECA\u665A\u8981\u56DE\u4F4F\u5904\uFF0C\u5148\u770B\u95E8\u6813\u5361\u6CA1\u5361\u7D27\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 104-board-fix
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u4ECE\u65E9\u5FD9\u5230\u665A\uFF0C\u662F\u6015\u6751\u91CC\u4ECA\u665A\u51FA\u4E8B\u5417\uFF1F"
      - "\u8FD9\u4E9B\u6728\u677F\u90FD\u662F\u521A\u6362\u4E0A\u7684\uFF1F"
      npcReplyLines:
      - "\u6015\u5F52\u6015\uFF0C\u6015\u4E5F\u5F97\u5148\u628A\u95E8\u8865\u4E0A\uFF0C\u4E0D\u7136\u591C\u91CC\u8C01\u90FD\u7761\u4E0D\u5B89\u3002"
      - "\u6751\u957F\u4E22\u4E0B\u7684\u70C2\u644A\u5B50\uFF0C\u603B\u4E0D\u80FD\u8BA9\u5B69\u5B50\u4EEC\u5148\u9876\u7740\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u8981\u662F\u6211\u4EE5\u540E\u6765\u5DE5\u4F5C\u53F0\uFF0C\u4F60\u53EF\u4EE5\u6559\u6211\u4FEE\u8FD9\u4E9B\u5417\uFF1F"
      - "\u6211\u60F3\u5B66\u70B9\u771F\u6B63\u80FD\u5E2E\u4E0A\u5FD9\u7684\u4E1C\u897F\u3002"
      npcReplyLines:
      - "\u53EF\u4EE5\uFF0C\u5148\u5B66\u628A\u624B\u4E0A\u8FD9\u4E00\u9524\u843D\u7A33\uFF0C\u518D\u8C08\u522B\u7684\u3002"
      - "\u4F1A\u4FEE\u4E1C\u897F\u7684\u4EBA\uFF0C\u81F3\u5C11\u4E0D\u5BB9\u6613\u88AB\u614C\u4E71\u7275\u7740\u8D70\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: "\u55EF"
    playerExitLines:
    - "\u6211\u5148\u53BB\u5FD9\u522B\u7684\uFF0C\u5F85\u4F1A\u513F\u518D\u6765\u3002"
    - "\u8FD9\u4E9B\u6728\u677F\u5148\u4EA4\u7ED9\u4F60\u4E86\u3002"
    npcReactionLines:
    - "\u53BB\u5427\uFF0C\u8DEF\u4E0A\u987A\u4FBF\u66FF\u6211\u770B\u770B\u54EA\u9762\u6805\u680F\u53C8\u677E\u4E86\u3002"
    - "\u4F60\u56DE\u6765\u8981\u662F\u8FD8\u6709\u529B\u6C14\uFF0C\u6211\u518D\u6559\u4F60\u4E0B\u4E00\u6B65\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u624B\u4E0A\u6709\u6D3B\uFF0C\u8111\u5B50\u5C31\u4E0D\u4F1A\u8001\u53BB\u60F3\u90A3\u4E9B\u8DD1\u6389\u7684\u4EBA\u3002"
  - "\u80FD\u4FEE\u597D\u7684\u5148\u4FEE\uFF0C\u5269\u4E0B\u7684\u518D\u6162\u6162\u8FFD\u8D23\u3002"
  defaultChatResponderLines:
  - "\u5BF9\uFF0C\u6211\u4E0D\u7231\u5435\uFF0C\u53EF\u603B\u5F97\u6709\u4EBA\u628A\u80FD\u505A\u7684\u5148\u505A\u5B8C\u3002"
  - "\u6751\u91CC\u73B0\u5728\u7F3A\u7684\u662F\u7A33\u624B\uFF0C\u4E0D\u662F\u66F4\u5927\u7684\u55D3\u95E8\u3002"
  pairDialogueSets:
  - partnerNpcId: 101
    initiatorLines:
    - "\u83B1\u672D\uFF0C\u4F60\u628A\u8C01\u9886\u8FC7\u677F\u6599\u8BB0\u6E05\u4E86\uFF0C\u7701\u5F97\u540E\u5934\u53C8\u6709\u4EBA\u8D56\u3002"
    - "\u6211\u4FEE\u95E8\u4FEE\u6805\u680F\uFF0C\u6700\u6015\u6700\u540E\u8FDE\u8C01\u52A8\u8FC7\u624B\u90FD\u8BF4\u4E0D\u660E\u767D\u3002"
    responderLines:
    - "\u653E\u5FC3\uFF0C\u4F60\u8FD9\u8FB9\u6BCF\u4E00\u5757\u6728\u6599\u6211\u90FD\u7ED9\u4F60\u7559\u7740\u5E95\u3002"
    - "\u7B49\u8D26\u548C\u95E8\u90FD\u8865\u9F50\u4E86\uFF0C\u8C01\u60F3\u7CCA\u5F04\u90FD\u96BE\u3002"
  - partnerNpcId: 103
    initiatorLines:
    - "\u963F\u6F88\uFF0C\u4F60\u8BF4\u7684\u65AD\u680F\u4F4D\u7F6E\u6211\u53BB\u770B\u8FC7\uFF0C\u811A\u5370\u786E\u5B9E\u5728\u90A3\u513F\u4E71\u4E86\u4E00\u6B21\u3002"
    - "\u4EE5\u540E\u4F60\u518D\u770B\u89C1\u4EC0\u4E48\uFF0C\u7B2C\u4E00\u65F6\u95F4\u5148\u6765\u6572\u6211\u8FD9\u8FB9\u7684\u95E8\u3002"
    responderLines:
    - "\u6211\u77E5\u9053\u5566\uFF0C\u6211\u8FD9\u56DE\u4E0D\u53EA\u4F1A\u8DD1\uFF0C\u8FD8\u4F1A\u5148\u628A\u5730\u65B9\u8BB0\u4F4F\u3002"
    - "\u6709\u4F60\u53BB\u770B\u8FC7\uFF0C\u6211\u5C31\u66F4\u6562\u8BF4\u90A3\u665A\u4E0D\u662F\u6211\u773C\u82B1\u3002"
  - partnerNpcId: 203
    initiatorLines:
    - "\u9EA6\u79BE\uFF0C\u4ECA\u665A\u8981\u662F\u8FD8\u6709\u4EBA\u5B88\u591C\uFF0C\u6211\u7ED9\u4F60\u90A3\u8FB9\u518D\u9489\u4E24\u5757\u6321\u98CE\u677F\u3002"
    - "\u4EBA\u5FC3\u4E00\u4E71\uFF0C\u80FD\u6321\u98CE\u6321\u96E8\u7684\u5730\u65B9\u5C31\u66F4\u4E0D\u80FD\u6F0F\u3002"
    responderLines:
    - "\u884C\u554A\uFF0C\u4F60\u628A\u95E8\u677F\u9489\u7A33\uFF0C\u6211\u8FD9\u8FB9\u628A\u70ED\u6C64\u4E00\u76F4\u70ED\u7740\u3002"
    - "\u591C\u91CC\u771F\u8981\u6709\u4EBA\u8DD1\u6765\u6C42\u4E2A\u5B89\u7A33\uFF0C\u5148\u770B\u5230\u7684\u603B\u5F97\u662F\u4EAE\u5802\u5802\u7684\u7076\u706B\u3002"

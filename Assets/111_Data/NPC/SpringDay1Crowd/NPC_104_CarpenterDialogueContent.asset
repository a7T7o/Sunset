  m_Name: NPC_104_CarpenterCrowdDialogueContent
  m_EditorClassIdentifier:
  npcId: 104
  selfTalkLines:
  - "\u4E00\u5230\u665A\u996D\u540E\uFF0C\u6572\u6728\u58F0\u5C31\u5F97\u8F7B\u4E00\u70B9\uFF0C\u4E0D\u7136\u6EE1\u6751\u90FD\u77E5\u9053\u8C01\u8FD8\u6CA1\u6562\u56DE\u5C4B\u3002"
  - "\u95E8\u6813\u548C\u7A97\u95E9\u6211\u90FD\u591A\u8865\u4E86\u4E00\u9053\uFF0C\u771F\u6709\u4EBA\u534A\u591C\u5FC3\u865A\uFF0C\u5148\u649E\u4E0A\u7684\u4E5F\u662F\u6728\u677F\u3002"
  - "\u660E\u65E9\u8BE5\u5F00\u7684\u95E8\u8FD8\u662F\u5F97\u7167\u65E7\u5F00\uFF0C\u4E0D\u80FD\u8BA9\u6751\u91CC\u4E00\u6563\u5C31\u53EA\u5269\u7A7A\u54CD\u3002"
  phaseSelfTalkLines:
  - storyPhase: 40
    selfTalkLines:
    - "\u5148\u628A\u95E8\u6813\u548C\u6728\u7F1D\u90FD\u770B\u4F4F\uFF0C\u54CD\u52A8\u6700\u4F1A\u987A\u7740\u5FC3\u614C\u4F20\u3002"
    - "\u5DE5\u4F5C\u53F0\u8FD9\u8FB9\u4E00\u54CD\uFF0C\u56DE\u5C4B\u524D\u90A3\u70B9\u72B9\u8C6B\u5C31\u85CF\u4E0D\u4F4F\u3002"
  - storyPhase: 60
    selfTalkLines:
    - "\u6728\u5934\u6572\u8F7B\u4E00\u70B9\uFF0C\u514D\u5F97\u628A\u684C\u8FB9\u90A3\u9635\u5FC3\u865A\u518D\u9707\u51FA\u6765\u3002"
    - "\u5148\u8865\u80FD\u6309\u7A33\u7684\u5730\u65B9\uFF0C\u591C\u91CC\u95E8\u677F\u6700\u6015\u8DDF\u7740\u4EBA\u5FC3\u4E00\u8D77\u677E\u3002"
  - storyPhase: 90
    selfTalkLines:
    - "\u95E8\u95E9\u5148\u9876\u4F4F\uFF0C\u5929\u4EAE\u4E86\u4EBA\u624D\u7AD9\u5F97\u7A33\u3002"
    - "\u660E\u65E9\u7167\u65E7\u5F00\u95E8\u5E72\u6D3B\uFF0C\u8FD9\u4E00\u591C\u7684\u614C\u624D\u4E0D\u4F1A\u8D8A\u6EDA\u8D8A\u5927\u3002"
  playerNearbyLines:
  - "\u56DE\u5C4B\u524D\u628A\u95E8\u6813\u518D\u6478\u4E00\u904D\uFF0C\u4ECA\u665A\u5927\u5BB6\u5FC3\u90FD\u60AC\u7740\uFF0C\u54CD\u4E00\u58F0\u90FD\u62DB\u4EBA\u4FA7\u773C\u3002"
  - "\u521A\u624D\u996D\u684C\u90A3\u8FB9\u4E00\u9759\uFF0C\u5916\u5934\u8FDE\u6572\u6728\u5934\u7684\u4EBA\u90FD\u81EA\u52A8\u628A\u529B\u9053\u538B\u4E0B\u6765\u4E86\u3002"
  - "\u7B49\u5929\u4E00\u4EAE\u6211\u8FD8\u5F97\u7167\u65E7\u8865\u6805\u680F\uFF0C\u6751\u91CC\u4E0D\u80FD\u56E0\u4E3A\u4E00\u4E2A\u4EBA\u8DD1\u4E86\u5C31\u5168\u505C\u5DE5\u3002"
  relationshipStageNearbyLines: []
  phaseNearbyLines:
  - storyPhase: 40
    playerNearbyLines:
    - "\u5DE5\u4F5C\u53F0\u8FD9\u8FB9\u4E00\u54CD\uFF0C\u56DE\u5C4B\u524D\u60F3\u591A\u542C\u4E00\u53E5\u7684\u4EBA\u811A\u6B65\u5C31\u4F1A\u6162\u4E0B\u6765\u3002"
    - "\u95E8\u677F\u4F1A\u54CD\uFF0C\u4EBA\u5FC3\u66F4\u4F1A\u54CD\uFF0C\u6211\u8FD9\u4F1A\u513F\u5148\u628A\u80FD\u6309\u7A33\u7684\u90FD\u6309\u4F4F\u3002"
  - storyPhase: 60
    playerNearbyLines:
    - "\u665A\u996D\u540E\u6572\u6728\u58F0\u90FD\u538B\u8F7B\u4E86\uFF0C\u5927\u5BB6\u6015\u518D\u54CD\u4E00\u58F0\u5C31\u628A\u5FC3\u865A\u6296\u51FA\u6765\u3002"
    - "\u8C01\u56DE\u5C4B\u524D\u8FD8\u5728\u95E8\u8FB9\u72B9\u8C6B\uFF0C\u6211\u4ECE\u6728\u5934\u56DE\u58F0\u91CC\u5C31\u542C\u5F97\u89C1\u3002"
  - storyPhase: 90
    playerNearbyLines:
    - "\u8FD9\u4F1A\u513F\u5148\u628A\u95E8\u95E9\u9876\u7A33\uFF0C\u6BD4\u7A7A\u7740\u624B\u80E1\u601D\u4E71\u60F3\u5F3A\u3002"

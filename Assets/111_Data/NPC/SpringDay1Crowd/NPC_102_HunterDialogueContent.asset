      exchanges:
      - exchangeId: exchange-1
        playerLines:
        - "\u56DE\u5C4B\u8FD9\u4E00\u8DEF\uFF0C\u4F60\u662F\u4E0D\u662F\u8FD8\u5728\u770B\u8C01\u7684\u811A\u6B65\u53D1\u865A\uFF1F"
        - "\u521A\u624D\u90A3\u9635\u63D0\u9192\u4E4B\u540E\uFF0C\u540E\u5761\u4F1A\u66F4\u5B89\u9759\u5417\uFF1F"
        npcReplyLines:
        - "\u8D8A\u63A5\u8FD1\u56DE\u5C4B\u7684\u65F6\u5019\uFF0C\u811A\u6B65\u8D8A\u5BB9\u6613\u628A\u5FC3\u865A\u9732\u51FA\u6765\u3002"

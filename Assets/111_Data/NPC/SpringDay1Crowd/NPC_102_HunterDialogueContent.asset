  m_Name: NPC_102_HunterClueDialogueContent
  m_EditorClassIdentifier:
  npcId: 102
  selfTalkLines:
  - "\u591C\u4E00\u6DF1\uFF0C\u540E\u5761\u90A3\u6BB5\u811A\u6B65\u5C31\u6BD4\u767D\u5929\u7684\u8BDD\u66F4\u771F\u3002"
  - "\u771F\u6709\u4EBA\u60F3\u88C5\u4F5C\u6751\u91CC\u7167\u5E38\u8F6C\uFF0C\u811A\u5370\u4E5F\u4F1A\u5148\u628A\u5FC3\u614C\u9732\u51FA\u6765\u3002"
  - "\u660E\u65E9\u5927\u5BB6\u7167\u6837\u5404\u7AD9\u5404\u7684\u4F4D\uFF0C\u6211\u8FD8\u662F\u5F97\u5148\u76EF\u6628\u665A\u8C01\u7ED5\u8FC7\u4E86\u6CB3\u6EE9\u3002"
  phaseSelfTalkLines:
  - storyPhase: 70
    selfTalkLines:
    - "\u5148\u522B\u628A\u811A\u5370\u8E29\u4E71\uFF0C\u56DE\u5C4B\u524D\u90A3\u51E0\u6B65\u6700\u4F1A\u9732\u5E95\u3002"
    - "\u98CE\u5411\u8FD8\u6CA1\u6362\uFF0C\u8C01\u5FC3\u865A\u6211\u5148\u4ECE\u788E\u77F3\u58F0\u91CC\u8BB0\u4E0B\u6765\u3002"
  - storyPhase: 80
    selfTalkLines:
    - "\u540E\u5761\u8FD9\u4F1A\u513F\u6700\u8BDA\u5B9E\uFF0C\u592A\u5B89\u9759\u53CD\u800C\u4E0D\u50CF\u6CA1\u4E8B\u3002"
    - "\u5148\u628A\u547C\u5438\u538B\u8F7B\uFF0C\u591C\u91CC\u4E71\u6389\u7684\u5F80\u5F80\u4E0D\u662F\u5F71\u5B50\u3002"
  - storyPhase: 90
    selfTalkLines:
    - "\u518D\u770B\u4E00\u5708\u5730\u9762\uFF0C\u6CA1\u7761\u7A33\u7684\u4EBA\u811A\u6B65\u603B\u4F1A\u53D1\u6563\u3002"
    - "\u5929\u4EAE\u80FD\u57CB\u4F4F\u4E00\u534A\u75D5\uFF0C\u57CB\u4E0D\u4F4F\u6628\u665A\u90A3\u4E00\u4E0B\u72B9\u8C6B\u3002"
  playerNearbyLines:
  - "\u4ECA\u665A\u8981\u5F80\u540E\u5761\u8D70\u7684\u8BDD\uFF0C\u5148\u542C\u4E00\u8033\u6735\u98CE\u91CC\u6709\u6CA1\u6709\u788E\u77F3\u54CD\u3002"
  - "\u522B\u770B\u767D\u5929\u5927\u5BB6\u88C5\u5F97\u7167\u65E7\uFF0C\u591C\u91CC\u4E00\u4E71\uFF0C\u811A\u6B65\u5C31\u5168\u9732\u5E95\u4E86\u3002"
  - "\u4F60\u771F\u60F3\u77E5\u9053\u90A3\u665A\u8C01\u5728\u770B\u8C01\uFF0C\u5148\u522B\u628A\u81EA\u5DF1\u811A\u6B65\u8E29\u4E71\u3002"
  relationshipStageNearbyLines: []
  phaseNearbyLines:
  - storyPhase: 70
    playerNearbyLines:
    - "\u56DE\u5C4B\u8FD9\u4E00\u8DEF\u7684\u811A\u6B65\u6700\u4F1A\u9732\u5E95\uFF0C\u4F60\u5148\u522B\u628A\u788E\u77F3\u8E29\u4E71\u3002"
    - "\u8FD9\u4F1A\u513F\u771F\u5FC3\u865A\u7684\u4EBA\uFF0C\u5F80\u5F80\u8D8A\u63A5\u8FD1\u4F4F\u5904\u8D8A\u88C5\u5F97\u592A\u7A33\u3002"
  - storyPhase: 80
    playerNearbyLines:
    - "\u591C\u91CC\u540E\u5761\u6700\u8BDA\u5B9E\uFF0C\u767D\u5929\u538B\u4E0B\u53BB\u7684\u72B9\u8C6B\u4F1A\u4ECE\u811A\u6B65\u91CC\u6F0F\u51FA\u6765\u3002"
    - "\u4F60\u8981\u662F\u4E5F\u5728\u542C\u52A8\u9759\uFF0C\u5C31\u5148\u628A\u81EA\u5DF1\u7684\u6B65\u5B50\u6536\u8F7B\u3002"
  - storyPhase: 90
    playerNearbyLines:
    - "\u6536\u591C\u540E\u518D\u770B\u4E00\u5708\uFF0C\u8C01\u6CA1\u7761\u5B89\u7A33\u5176\u5B9E\u7792\u4E0D\u8FC7\u5730\u9762\u3002"
    - "\u5929\u4E00\u4EAE\u75D5\u4F1A\u6DE1\uFF0C\u53EF\u6628\u665A\u90A3\u70B9\u614C\u4E0D\u4F1A\u8FD9\u4E48\u5FEB\u5168\u57CB\u4F4F\u3002"
  defaultInformalConversationBundles:
  - bundleId: 102-trail-watch
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u662F\u4E0D\u662F\u5DF2\u7ECF\u627E\u5230\u6751\u957F\u8DD1\u8D70\u7684\u65B9\u5411\u4E86\uFF1F"
      - "\u770B\u4F60\u76EF\u7740\u5730\u9762\u5F88\u4E45\u4E86\u3002"
      npcReplyLines:
      - "\u5927\u65B9\u5411\u77E5\u9053\uFF0C\u53EF\u60DC\u5BF9\u65B9\u592A\u4F1A\u62B9\u75D5\uFF0C\u50CF\u662F\u65E9\u628A\u600E\u4E48\u8EB2\u4EBA\u60F3\u597D\u4E86\u3002"
      - "\u6211\u53EA\u5DEE\u4E00\u70B9\u70B9\u5C31\u80FD\u54AC\u4F4F\u540E\u534A\u7A0B\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u8981\u662F\u6211\u5E2E\u4F60\u4E00\u8D77\u770B\uFF0C\u4F1A\u4E0D\u4F1A\u5FEB\u4E00\u70B9\uFF1F"
      - "\u6211\u8DEF\u8FC7\u6CB3\u8FB9\u65F6\u53EF\u4EE5\u66FF\u4F60\u77A7\u4E00\u773C\u3002"
      npcReplyLines:
      - "\u4F1A\uFF0C\u4F60\u773C\u775B\u8981\u662F\u591F\u7EC6\uFF0C\u80FD\u5E2E\u6211\u7701\u4E0B\u534A\u5929\u515C\u5708\u5B50\u3002"
      - "\u4F46\u771F\u78B0\u89C1\u4E0D\u5BF9\u52B2\u7684\u4EBA\uFF0C\u4F60\u5148\u987E\u597D\u81EA\u5DF1\uFF0C\u522B\u901E\u5F3A\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []

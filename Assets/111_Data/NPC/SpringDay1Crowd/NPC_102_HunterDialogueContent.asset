  m_Script: {fileID: 11500000, guid: 7e1d8fd01cb8442eb570f1fd4d33ac41, type: 3}
  m_Name: NPC_102_HunterClueDialogueContent
  m_EditorClassIdentifier: 
  npcId: 102
  selfTalkLines:
  - "\u811A\u5370\u5230\u6CB3\u6EE9\u5C31\u65AD\u4E86\uFF0C\u50CF\u662F\u65E9\u6709\u4EBA\u5728\u90A3\u513F\u63A5\u5E94\u3002"
  - "\u6751\u957F\u4E0D\u662F\u614C\u7740\u8DD1\u7684\uFF0C\u4ED6\u8D70\u5F97\u6BD4\u91CE\u5154\u8FD8\u4F1A\u85CF\u5C3E\u5DF4\u3002"
  - "\u6211\u8981\u662F\u518D\u665A\u534A\u523B\u949F\u8FFD\u51FA\u53BB\uFF0C\u73B0\u5728\u5C31\u4E0D\u4F1A\u53EA\u5269\u8FD9\u4E9B\u788E\u7EBF\u7D22\u3002"
  playerNearbyLines:
  - "\u4F60\u811A\u6B65\u8F7B\uFF0C\u522B\u8E29\u574F\u6211\u76EF\u7740\u7684\u8FD9\u4E32\u5370\u5B50\u3002"
  - "\u60F3\u542C\u5B9E\u8BDD\uFF1F\u6211\u4E0D\u4FE1\u90A3\u8001\u4E1C\u897F\u662F\u4E00\u4E2A\u4EBA\u8DD1\u7684\u3002"
  - "\u8981\u662F\u4F60\u5F80\u4E1C\u8FB9\u53BB\uFF0C\u66FF\u6211\u7559\u610F\u6709\u4EBA\u85CF\u8239\u6CA1\u6709\u3002"
  relationshipStageNearbyLines: []
  defaultInformalConversationBundles:
  - bundleId: 102-trail-watch
    exchanges:
    - exchangeId: exchange-1
      playerLines:
      - "\u4F60\u662F\u4E0D\u662F\u5DF2\u7ECF\u627E\u5230\u6751\u957F\u8DD1\u8D70\u7684\u65B9\u5411\u4E86\uFF1F"
      - "\u770B\u4F60\u76EF\u7740\u5730\u9762\u5F88\u4E45\u4E86\u3002"
      npcReplyLines:
      - "\u5927\u65B9\u5411\u77E5\u9053\uFF0C\u53EF\u60DC\u5BF9\u65B9\u592A\u4F1A\u62B9\u75D5\uFF0C\u50CF\u8001\u65E9\u5C31\u6392\u7EC3\u8FC7\u3002"
      - "\u6211\u53EA\u5DEE\u4E00\u70B9\u70B9\u5C31\u80FD\u54AC\u4F4F\u540E\u534A\u7A0B\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    - exchangeId: exchange-2
      playerLines:
      - "\u8981\u662F\u6211\u5E2E\u4F60\u4E00\u8D77\u770B\uFF0C\u4F1A\u4E0D\u4F1A\u5FEB\u4E00\u70B9\uFF1F"
      - "\u6211\u8DEF\u8FC7\u6CB3\u8FB9\u65F6\u53EF\u4EE5\u66FF\u4F60\u77A7\u4E00\u773C\u3002"
      npcReplyLines:
      - "\u4F1A\uFF0C\u4F60\u773C\u775B\u8981\u662F\u591F\u7EC6\uFF0C\u80FD\u5E2E\u6211\u7701\u4E0B\u534A\u5929\u515C\u5708\u5B50\u3002"
      - "\u4F46\u771F\u78B0\u89C1\u4E0D\u5BF9\u52B2\u7684\u4EBA\uFF0C\u4F60\u5148\u987E\u597D\u81EA\u5DF1\uFF0C\u522B\u901E\u5F3A\u3002"
      npcReplyDelayMin: 0.52
      npcReplyDelayMax: 0.86
    completionRelationshipDelta: 1
  relationshipStageInformalChatSets: []
  defaultWalkAwayReaction:
    reactionCue: "\u5567"
    playerExitLines:
    - "\u6211\u5148\u53BB\u524D\u9762\u770B\u770B\u3002"
    - "\u4F60\u7EE7\u7EED\u5B88\u7740\u8FD9\u8FB9\u5427\u3002"
    npcReactionLines:
    - "\u6210\uFF0C\u522B\u628A\u6211\u8FD9\u70B9\u7EBF\u7D22\u8E29\u6563\u4E86\u3002"
    - "\u6709\u52A8\u9759\u5C31\u558A\u6211\uFF0C\u6211\u8DD1\u5F97\u5FEB\u3002"
    relationshipDelta: 0
    npcReactionDelay: 0.4
  defaultInterruptRules: []
  defaultResumeRules: []
  defaultChatInitiatorLines:
  - "\u8FD9\u6751\u5B50\u5B89\u9759\u5F97\u4E0D\u5BF9\uFF0C\u50CF\u72FC\u6765\u4E4B\u524D\u7684\u6797\u5B50\u3002"
  - "\u6211\u5B81\u53EF\u8FFD\u7A7A\u4E00\u6574\u5929\uFF0C\u4E5F\u4E0D\u60F3\u8BA9\u90A3\u4EBA\u8DD1\u5F97\u592A\u8F7B\u677E\u3002"
  defaultChatResponderLines:
  - "\u55EF\uFF0C\u771F\u8981\u628A\u4EBA\u8FFD\u56DE\u6765\uFF0C\u8FD8\u5F97\u9760\u66F4\u591A\u773C\u775B\u3002"
  - "\u6211\u53EA\u4FE1\u811A\u5370\u548C\u98CE\u5411\uFF0C\u5634\u4E0A\u7684\u5B89\u7A33\u4E0D\u7B97\u6570\u3002"
  pairDialogueSets:
  - partnerNpcId: 301
    initiatorLines:
    - "\u4F60\u5B88\u591C\u8DEF\u8FD9\u4E48\u4E45\uFF0C\u540E\u5761\u90A3\u4E32\u788E\u77F3\u5230\u5E95\u5F80\u54EA\u8FB9\u62D0\u4E86\uFF1F"
    - "\u6211\u8FFD\u767D\u5929\u7684\u811A\u5370\uFF0C\u4F60\u8BB0\u591C\u91CC\u7684\u56DE\u58F0\uFF0C\u6211\u4EEC\u8BE5\u80FD\u62FC\u51FA\u4E00\u6761\u7EBF\u3002"
    responderLines:
    - "\u6211\u542C\u89C1\u7684\u65B9\u5411\u548C\u4F60\u731C\u7684\u5DEE\u4E0D\u79BB\uFF0C\u53EA\u662F\u90A3\u4EBA\u6BD4\u98CE\u8FD8\u5FC3\u865A\u3002"
    - "\u4F60\u76EF\u767D\u5929\uFF0C\u6211\u770B\u9ED1\u8DEF\uFF0C\u8FDF\u65E9\u628A\u4ED6\u6015\u7684\u5730\u65B9\u6316\u51FA\u6765\u3002"

  dialogueContentProfile: {fileID: 11400000, guid: 7e2b0033c7f84db9919d4b49c4ae3303, type: 2}
  selfTalkLines:
  - "\u5149\u7167\u89D2\u5EA6\u6BD4\u6211\u521A\u624D\u4F30\u7684\u66F4\u7A33\u5B9A\u3002"
  - "\u5982\u679C\u4ECE\u8FD9\u91CC\u89C2\u5BDF\uFF0C\u8DEF\u7EBF\u53D8\u5316\u4F1A\u66F4\u6E05\u695A\u3002"
  - "\u5148\u628A\u987A\u5E8F\u8BB0\u4E0B\u6765\uFF0C\u514D\u5F97\u7B49\u4F1A\u513F\u53C8\u5FD8\u4E86\u3002"
  - "\u55EF\uFF0C\u8FD9\u4E2A\u8DDD\u79BB\u8BF4\u8BDD\u548C\u79FB\u52A8\u90FD\u6BD4\u8F83\u5408\u9002\u3002"
  - "\u6211\u5F97\u518D\u786E\u8BA4\u4E00\u904D\u8282\u594F\u662F\u4E0D\u662F\u8FD8\u662F\u592A\u5FEB\u4E86\u3002"
  chatInitiatorLines:
  - "\u6211\u521A\u5728\u8BB0\u8FD9\u8FB9\u7684\u901A\u884C\u8282\u594F\u3002"
  - "\u4F60\u8981\u662F\u4E0D\u6025\uFF0C\u6211\u60F3\u518D\u770B\u4E00\u773C\u8FD9\u91CC\u7684\u53D8\u5316\u3002"
  - "\u8FD9\u6761\u8DEF\u7684\u95F4\u8DDD\u53EF\u80FD\u6BD4\u6211\u60F3\u7684\u66F4\u654F\u611F\u3002"
  chatResponderLines:
  - "\u7A0D\u7B49\uFF0C\u6211\u60F3\u5148\u628A\u8FD9\u4E2A\u73B0\u8C61\u8BB0\u5B8C\u3002"
  - "\u4F60\u8FD9\u4E48\u4E00\u8BF4\uFF0C\u5012\u8DDF\u6211\u521A\u624D\u7684\u63A8\u6D4B\u5BF9\u4E0A\u4E86\u3002"
  - "\u884C\uFF0C\u6211\u518D\u770B\u4E24\u773C\u5C31\u6362\u4E2A\u4F4D\u7F6E\u3002"
